local function rejoinThisServer()
	local ok, err = pcall(function()
		TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId)
	end)
	if not ok then
		warn("[Join Server] Rejoin failed:", err)
	end
end

local function joinNewServer()
	local ok, err = pcall(function()
		TeleportService:Teleport(game.PlaceId)
	end)
	if not ok then
		warn("[Join Server] Join new failed:", err)
	end
end

rejoinBtn.MouseButton1Click:Connect(rejoinThisServer)
newServerBtn.MouseButton1Click:Connect(joinNewServer)

local joinPanelVisible = false
local function toggleJoinPanel()
	joinPanelVisible = not joinPanelVisible
	joinFrame.Visible = joinPanelVisible
end

toggleJoinBtn.MouseButton1Click:Connect(toggleJoinPanel)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.J then
		toggleJoinPanel()
	end
end)
