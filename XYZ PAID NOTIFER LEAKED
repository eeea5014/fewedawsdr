-- ========================================
-- STATS MANAGEMENT
-- ========================================

function XYZNotifier:UpdateStats()
    if not self.statsText then
        return
    end
    
    local totalFound = 0
    for _ in pairs(self.foundBrainrots) do
        totalFound = totalFound + 1
    end
    
    local status = self.isRunning and "ON" or "OFF"
    self.statsText.Text = "Found: " .. totalFound .. " | Scanning: " .. status
end

-- ========================================
-- SERVER SCANNING
-- ========================================

function XYZNotifier:GetPublicServers()
    local servers = {}
    local gameId = Config.GAME_ID
    
    local success, response = pcall(function()
        return HttpService:GetAsync(
            "https://www.roblox.com/games/getgameinstances?placeId=" .. tostring(gameId),
            true
        )
    end)
    
    if success then
        local decoded = HttpService:JSONDecode(response)
        if decoded and decoded.collection then
            for _, server in ipairs(decoded.collection) do
                table.insert(servers, {
                    id = server.id,
                    name = server.name or "Public Server",
                    players = server.players or {},
                    maxPlayers = server.maxPlayers or 50
                })
            end
        end
    end
    
    return servers
end

function XYZNotifier:GetPlayerBases()
    local bases = {}
    local gameId = Config.GAME_ID
    
    local success, response = pcall(function()
        return HttpService:GetAsync(
            "https://www.roblox.com/games/servers?placeId=" .. tostring(gameId) .. "&sortOrder=Asc&pageNumber=1",
            true
        )
    end)
    
    if success then
        local decoded = HttpService:JSONDecode(response)
        if decoded and decoded.data then
            for _, server in ipairs(decoded.data) do
                if string.find(string.lower(server.name), string.lower(Config.PLAYER_BASE_KEYWORD)) then
                    table.insert(bases, {
                        id = server.id,
                        name = server.name,
                        players = server.players or {},
                        maxPlayers = server.maxPlayers or 50
                    })
                end
            end
        end
    end
    
    return bases
end

function XYZNotifier:GetPlayerBrainrots(player)
    local brainrots = {}
    
    if player:FindFirstChild("Inventory") then
        local inventory = player.Inventory
        for _, item in ipairs(inventory:GetChildren()) do
            if item:FindFirstChild("IsBrainrot") and item.IsBrainrot.Value then
                table.insert(brainrots, {
                    name = item.Name,
                    rarity = item:FindFirstChild("Rarity") and item.Rarity.Value or "Unknown"
                })
            end
        end
    end
    
    return brainrots
end

function XYZNotifier:IsNeededBrainrot(brainrotName)
    for _, needed in ipairs(Config.NEEDED_BRAINROTS) do
        if string.lower(brainrotName) == string.lower(needed) then
            return true
        end
    end
    return false
end

-- ========================================
-- MAIN SCANNING LOOP
-- ========================================

function XYZNotifier:ScanCycle()
    if not self.isRunning then
        return
    end
    
    print("[XYZ] Scan cycle started")
    
    -- Get servers
    local publicServers = Config.SCAN_PUBLIC_SERVERS and self:GetPublicServers() or {}
    local playerBases = Config.SCAN_PLAYER_BASES and self:GetPlayerBases() or {}
    
    print("[XYZ] Found " .. #publicServers .. " public servers, " .. #playerBases .. " player bases")
    
    -- Combine servers
    local allServers = {}
    for _, server in ipairs(publicServers) do
        table.insert(allServers, server)
    end
    for _, base in ipairs(playerBases) do
        table.insert(allServers, base)
    end
    
    -- Scan each server
    for _, server in ipairs(allServers) do
        if self.isRunning then
            local brainrotsFound = false
            
            for _, player in ipairs(server.players) do
                local playerObj = game.Players:FindFirstChild(player)
                if playerObj then
                    local brainrots = self:GetPlayerBrainrots(playerObj)
                    for _, brainrot in ipairs(brainrots) do
                        if self:IsNeededBrainrot(brainrot.name) then
                            print("[XYZ] FOUND: " .. brainrot.name .. " owned by " .. player .. " in " .. server.name)
                            
                            self.foundBrainrots[brainrot.name] = (self.foundBrainrots[brainrot.name] or 0) + 1
                            self:DisplayNotification(brainrot.name, player, server.name)
                            brainrotsFound = true
                        end
                    end
                end
            end
        end
    end
    
    print("[XYZ] Scan cycle completed")
end

-- ========================================
-- MAIN CONTROL FUNCTIONS
-- ========================================

function XYZNotifier:Start()
    if self.isRunning then
        return
    end
    
    print("[XYZ] Starting notifier...")
    self.isRunning = true
    
    if self.statusLight then
        self.statusLight.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    end
    
    self:UpdateStats()
    
    -- Main loop
    while self.isRunning do
        local success, error = pcall(function()
            self:ScanCycle()
        end)
        
        if not success then
            print("[XYZ ERROR] " .. tostring(error))
        end
        
        wait(Config.SCAN_INTERVAL)
    end
end

function XYZNotifier:Stop()
    print("[XYZ] Stopping notifier...")
    self.isRunning = false
    
    if self.statusLight then
        self.statusLight.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
    
    self:UpdateStats()
end

