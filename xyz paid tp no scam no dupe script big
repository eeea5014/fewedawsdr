-- Make frame draggable
local dragging = false
local dragStart = nil
local startPos = nil

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Create teleport zones in workspace (visual indicators)
local function createTeleportZone(name, position, color)
    local zone = Instance.new("Part")
    zone.Name = name
    zone.Parent = workspace
    zone.Anchored = true
    zone.CanCollide = false
    zone.Size = Vector3.new(8, 0.2, 8)
    zone.Position = position
    zone.BrickColor = color
    zone.Transparency = 0.3
    
    local sign = Instance.new("BillboardGui")
    sign.Parent = zone
    sign.Size = UDim2.new(0, 100, 0, 50)
    sign.StudsOffset = Vector3.new(0, 3, 0)
    
    local label = Instance.new("TextLabel")
    label.Parent = sign
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSansBold
    label.Text = "TELEPORT HERE (" .. name .. ")"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 14
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.TextStrokeTransparency = 0
    
    return zone
end

