-- Teleport function with smooth animation
local function teleportTo(location)
    if not isActive then
        player:WaitForChild("PlayerGui"):WaitForChild("TeleportSystem"):WaitForChild("MainFrame"):WaitForChild("ActivateButton")
        -- Visual feedback that activation is required
        local flash = Instance.new("Frame")
        flash.Parent = mainFrame
        flash.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        flash.BackgroundTransparency = 0
        flash.BorderSizePixel = 0
        flash.Size = UDim2.new(1, 0, 1, 0)
        flash.Position = UDim2.new(0, 0, 0, 0)
        flash.ZIndex = 10
        
        local tween = TweenService:Create(flash, TweenInfo.new(0.5), {BackgroundTransparency = 1})
        tween:Play()
        tween.Completed:Connect(function()
            flash:Destroy()
        end)
        return
    end
    
    local character = player.Character
    if character and character:FindFirstChild("HumanoidRootPart") then
        local humanoidRootPart = character.HumanoidRootPart
        
        -- Create teleport effect
        local effect = Instance.new("Part")
        effect.Parent = workspace
        effect.Anchored = true
        effect.CanCollide = false
        effect.Size = Vector3.new(1, 1, 1)
        effect.Position = humanoidRootPart.Position
        effect.BrickColor = BrickColor.new("Bright blue")
        effect.Transparency = 0.5
        
        local mesh = Instance.new("SpecialMesh", effect)
        mesh.MeshType = Enum.MeshType.Sphere
        mesh.Scale = Vector3.new(0.1, 0.1, 0.1)
        
        local expandTween = TweenService:Create(mesh, TweenInfo.new(0.5), {Scale = Vector3.new(10, 10, 10)})
        local fadeTween = TweenService:Create(effect, TweenInfo.new(0.5), {Transparency = 1})
        
        expandTween:Play()
        fadeTween:Play()
        
        -- Teleport player
        humanoidRootPart.CFrame = CFrame.new(location)
        
        -- Create arrival effect
        local arrivalEffect = Instance.new("Part")
        arrivalEffect.Parent = workspace
        arrivalEffect.Anchored = true
        arrivalEffect.CanCollide = false
        arrivalEffect.Size = Vector3.new(1, 1, 1)
        arrivalEffect.Position = location
        arrivalEffect.BrickColor = BrickColor.new("Bright green")
        arrivalEffect.Transparency = 0.5
        
        local arrivalMesh = Instance.new("SpecialMesh", arrivalEffect)
        arrivalMesh.MeshType = Enum.MeshType.Sphere
        arrivalMesh.Scale = Vector3.new(10, 10, 10)
        
        local shrinkTween = TweenService:Create(arrivalMesh, TweenInfo.new(0.5), {Scale = Vector3.new(0.1, 0.1, 0.1)})
        local arrivalFadeTween = TweenService:Create(arrivalEffect, TweenInfo.new(0.5), {Transparency = 1})
        
        shrinkTween:Play()
        arrivalFadeTween:Play()
        
        -- Clean up effects
        fadeTween.Completed:Connect(function()
            effect:Destroy()
        end)
        
        arrivalFadeTween.Completed:Connect(function()
            arrivalEffect:Destroy()
        end)
        
        -- Notification
        local notification = Instance.new("TextLabel")
        notification.Parent = screenGui
        notification.BackgroundTransparency = 0
        notification.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        notification.BorderSizePixel = 0
        notification.Position = UDim2.new(0.5, -100, 0, 50)
        notification.Size = UDim2.new(0, 200, 0, 30)
        notification.Font = Enum.Font.SourceSansBold
        notification.Text = "Teleported Successfully!"
        notification.TextColor3 = Color3.fromRGB(255, 255, 255)
        notification.TextSize = 16
        
        local moveTween = TweenService:Create(notification, TweenInfo.new(2), {Position = UDim2.new(0.5, -100, 0, 100)})
        local fadeOutTween = TweenService:Create(notification, TweenInfo.new(2), {BackgroundTransparency = 1, TextTransparency = 1})
        
        moveTween:Play()
        fadeOutTween:Play()
        
        fadeOutTween.Completed:Connect(function()
            notification:Destroy()
        end)
    end
end

