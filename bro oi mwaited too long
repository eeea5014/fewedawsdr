--// Find Remotes
local Remotes = {}
local function FindRemotes()
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            --// Quest Remotes
            if name:find("quest") and (name:find("complete") or name:find("claim")) then
                Remotes.Quest = v
                Debug("Found Quest Remote: " .. v.Name)
            end
            --// Battle Remotes
            if name:find("battle") or name:find("duel") or name:find("pvp") then
                Remotes.Battle = v
                Debug("Found Battle Remote: " .. v.Name)
            end
            --// Open Case
            if name:find("open") and name:find("case") then
                Remotes.OpenCase = v
                Debug("Found OpenCase Remote: " .. v.Name)
            end
            --// Sell
            if name:find("sell") then
                Remotes.Sell = v
                Debug("Found Sell Remote: " .. v.Name)
            end
        end
    end
end

FindRemotes()

--// Auto Quest Function
local function DoAutoQuest()
    while Settings.Running do
        if Settings.AutoQuest then
            Debug("Looking for quests...")
            
            --// Try remote first
            if Remotes.Quest then
                pcall(function()
                    Remotes.Quest:FireServer("CompleteAll")
                    Remotes.Quest:FireServer("ClaimAll")
                end)
            end
            
            --// UI Method - Find quest buttons
            local questUI = PlayerGui:FindFirstChild("Quests") or PlayerGui:FindFirstChild("QuestUI") or PlayerGui:FindFirstChild("DailyQuests")
            if questUI then
                --// Look for claim buttons
                for _, button in pairs(questUI:GetDescendants()) do
                    if button:IsA("TextButton") or button:IsA("ImageButton") then
                        local text = button.Text:lower()
                        if text:find("claim") or text:find("complete") or button.Name:lower():find("claim") then
                            --// Click it
                            local pos = button.AbsolutePosition
                            VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 15, 0, true, game, 0)
                            task.wait(0.1)
                            VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 15, 0, false, game, 0)
                            QuestsCompleted = QuestsCompleted + 1
                            QuestsValue.Text = tostring(QuestsCompleted)
                            Debug("Quest Claimed!")
                            task.wait(1)
                        end
                    end
                end
            end
            
            task.wait(3)
        else
            task.wait(0.5)
        end
    end
end

--// Auto Win Battle
local function DoAutoWinBattle()
    while Settings.Running do
        if Settings.AutoWinBattle then
            Debug("Scanning for battles...")
            
            --// Method 1: Remote manipulation
            if Remotes.Battle then
                pcall(function()
                    --// Force win battle
                    Remotes.Battle:FireServer("Win")
                    Remotes.Battle:FireServer("ForceWin")
                    Remotes.Battle:FireServer("SetWinner", LocalPlayer.UserId)
                end)
            end
            
            --// Method 2: UI Manipulation
            local battleUI = PlayerGui:FindFirstChild("Battle") or PlayerGui:FindFirstChild("CaseBattle") or PlayerGui:FindFirstChild("PvP")
            if battleUI then
                --// Look for win indicators or join buttons
                for _, obj in pairs(battleUI:GetDescendants()) do
                    if obj:IsA("TextButton") then
                        local txt = obj.Text:lower()
                        if txt:find("join") or txt:find("battle") or txt:find("fight") then
                            --// Click join
                            local pos = obj.AbsolutePosition
                            VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 15, 0, true, game, 0)
                            task.wait(0.1)
                            VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 15, 0, false, game, 0)
                            Debug("Joined Battle!")
                            task.wait(2)
                        end
                    end
                end
            end
            
            --// Check if in battle and force win
            local battleFrame = PlayerGui:FindFirstChild("BattleFrame") or PlayerGui:FindFirstChild("BattleGui")
            if battleFrame then
                --// Try to manipulate results
                for _, v in pairs(battleFrame:GetDescendants()) do
                    if v:IsA("TextLabel") and v.Text:find("VS") then
                        --// We are in battle, try to win
                        if Remotes.Battle then
                            pcall(function()
                                Remotes.Battle:FireServer("WinBattle")
                                Remotes.Battle:FireServer("SetResult", "Win")
                            end)
                        end
                        BattlesWon = BattlesWon + 1
                        BattlesValue.Text = tostring(BattlesWon)
                        Debug("Battle Won!")
                        task.wait(5)
                    end
                end
            end
            
            task.wait(2)
        else
            task.wait(0.5)
        end
    end
end

--// Auto Open Level Case (NO FREE CASES - Uses your 12k!)
local function DoAutoOpenLevel()
    while Settings.Running do
        if Settings.AutoOpenLevelCase then
            Debug("Opening best available case...")
            
            --// Get player level to determine case
            local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
            local level = 1
            if leaderstats then
                local lvlStat = leaderstats:FindFirstChild("Level") or leaderstats:FindFirstChild("Lvl")
                if lvlStat then
                    level = tonumber(lvlStat.Value) or 1
                end
            end
            
            --// Determine best case based on level and cash
            local caseToOpen = "Basic Case"
            if level >= 50 then
                caseToOpen = "Legendary Case"
            elseif level >= 30 then
                caseToOpen = "Epic Case"
            elseif level >= 15 then
                caseToOpen = "Rare Case"
            end
            
            --// Open via remote
            if Remotes.OpenCase then
                pcall(function()
                    Remotes.OpenCase:FireServer(caseToOpen)
                    CasesOpened = CasesOpened + 1
                    CasesValue.Text = tostring(CasesOpened)
                    Debug("Opened: " .. caseToOpen)
                end)
            else
                --// UI Method
                local caseBtn = PlayerGui:FindFirstChild("OpenCase", true) or PlayerGui:FindFirstChild("CaseButton", true)
                if caseBtn then
                    local pos = caseBtn.AbsolutePosition
                    VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 25, 0, true, game, 0)
                    task.wait(0.1)
                    VirtualInputManager:SendMouseButtonEvent(pos.X + 50, pos.Y + 25, 0, false, game, 0)
                    CasesOpened = CasesOpened + 1
                    CasesValue.Text = tostring(CasesOpened)
                end
            end
            
            task.wait(4 + math.random() * 2) -- Random delay 4-6s
        else
            task.wait(0.5)
        end
    end
end

--// Auto Sell
local function DoAutoSell()
    while Settings.Running do
        if Settings.AutoSell then
            Debug("Selling low value items...")
            
            if Remotes.Sell then
                pcall(function()
                    --// Sell specific rarities
                    if Settings.AutoSellRarities.Common then
                        Remotes.Sell:FireServer("Common")
                    end
                    if Settings.AutoSellRarities.Uncommon then
                        Remotes.Sell:FireServer("Uncommon")
                    end
                    Remotes.Sell:FireServer("SellDuplicates")
                end)
            end
            
            task.wait(10)
        else
            task.wait(1)
        end
    end
end

