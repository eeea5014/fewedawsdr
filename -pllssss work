        stats.Stolen = stats.Stolen + 1
        updateStats()
        notifFrame.BackgroundColor3 = Color3.fromRGB(50, 100, 50)
        stealBtn.Text = "✓"
        stealBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    end)
    
    -- Animation
    notifFrame.Size = UDim2.new(0, 0, 0, 80)
    TweenService:Create(notifFrame, TweenInfo.new(0.3), {Size = UDim2.new(1, -10, 0, 80)}):Play()
    
    -- Sound Effect
    if CONFIG.SoundEnabled then
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://9113083740" -- Notification sound
        sound.Volume = 0.5
        sound.Parent = notifFrame
        sound:Play()
    end
    
    -- Auto remove after duration
    table.insert(activeNotifications, notifFrame)
    if #activeNotifications > CONFIG.MaxNotifications then
        local old = table.remove(activeNotifications, 1)
        if old then old:Destroy() end
    end
    
    delay(CONFIG.NotificationDuration, function()
        if notifFrame and notifFrame.Parent then
            TweenService:Create(notifFrame, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
            for _, child in pairs(notifFrame:GetDescendants()) do
                if child:IsA("GuiObject") then
                    TweenService:Create(child, TweenInfo.new(0.5), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
                end
            end
            wait(0.5)
            if notifFrame then notifFrame:Destroy() end
        end
    end)
    
    stats.Found = stats.Found + 1
    updateStats()
end

function updateStats()
    statsText.Text = string.format("Found: %d | Stolen: %d | Missed: %d", stats.Found, stats.Stolen, stats.Missed)
end

-- SCANNING SYSTEM
function scanForBrainrots()
    -- This function would interface with the game's actual objects
    -- Looking for brainrots on conveyor belt, in other players' bases, etc.
    
    -- Example: Scan workspace for brainrot models
    local workspace = game:GetService("Workspace")
    
    -- Look for conveyor belt items (this is game-specific)
    local conveyor = workspace:FindFirstChild("Conveyor") or workspace:FindFirstChild("ConveyorBelt")
    if conveyor then
        for _, item in pairs(conveyor:GetDescendants()) do
            if item:IsA("Model") or item:IsA("Part") then
                local name = item.Name
                local rarity = BRAINROT_LOOKUP[name]
                if rarity then
                    createNotification(name, rarity, "Conveyor Belt")
                end
            end
        end
    end
    
    -- Scan other players' bases
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local base = workspace:FindFirstChild(otherPlayer.Name.."_Base") or workspace:FindFirstChild(otherPlayer.Name)
            if base then
                for _, item in pairs(base:GetDescendants()) do
                    if item:IsA("Model") or item:IsA("Part") then
                        local name = item.Name
                        local rarity = BRAINROT_LOOKUP[name]
                        if rarity and (rarity == "OG" or rarity == "Secret" or rarity == "Brainrot God") then
                            createNotification(name, rarity, otherPlayer.Name.."'s Base")
                        end
                    end
                end
            end
        end
    end
end

