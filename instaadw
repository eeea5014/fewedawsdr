-- Status label
local statusLabel = Instance.new("TextLabel")
statusLabel.Name = "Status"
statusLabel.Size = UDim2.new(1, -20, 0, 25)
statusLabel.Position = UDim2.new(0, 10, 0, 40)
statusLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
statusLabel.Text = "Instant TP: OFF"
statusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
statusLabel.Font = Enum.Font.Gotham
statusLabel.TextSize = 14
statusLabel.Parent = mainFrame

local statusCorner = Instance.new("UICorner")
statusCorner.CornerRadius = UDim.new(0, 4)
statusCorner.Parent = statusLabel

-- Draggable functionality
local dragging = false
local dragInput, dragStart, startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ANTI-CHEAT BYPASS METHODS

-- Method 1: Physics-based teleport (looks like high speed movement)
local function physicsTeleport(targetPos)
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = (targetPos - humanoidRootPart.Position).Unit * teleportSpeed
    bodyVelocity.Parent = humanoidRootPart

    local connection
    connection = RunService.Heartbeat:Connect(function()
        if (humanoidRootPart.Position - targetPos).Magnitude < 5 then
            bodyVelocity:Destroy()
            connection:Disconnect()
            humanoidRootPart.CFrame = CFrame.new(targetPos)
        end
    end)
end

-- Method 2: Tween-based (smooth movement)
local function tweenTeleport(targetPos)
    local distance = (targetPos - humanoidRootPart.Position).Magnitude
    local time = distance / teleportSpeed

    local tween = TweenService:Create(
        humanoidRootPart,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(targetPos)}
    )
    tween:Play()
end

-- Method 3: Network sync (most stealthy - uses network ownership)
local function networkTeleport(targetPos)
    -- Temporarily disable character interpolation
    local oldCFrame = humanoidRootPart.CFrame

    -- Set network owner to nil briefly
    if humanoidRootPart:IsA("BasePart") then
        humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        humanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
    end

    -- Small delay to sync
    task.wait(0.03)
    humanoidRootPart.CFrame = CFrame.new(targetPos)

    -- Restore velocity to prevent detection
    humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
end

-- Check if holding carpet
local function isHoldingCarpet()
    local tool = character:FindFirstChildOfClass("Tool")
    if tool and tool.Name:lower():find(carpetName:lower()) then
        return true
    end

    -- Check backpack for equipped tool
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item.Name:lower():find(carpetName:lower()) then
                -- Check if it's equipped
                if character:FindFirstChild(item.Name) then
                    return true
                end
            end
        end
    end

    return false
end

-- Main teleport logic
local isEnabled = false
local checkConnection

local function startChecking()
    if checkConnection then return end

    checkConnection = RunService.Heartbeat:Connect(function()
        if isEnabled and isHoldingCarpet() then
            -- Check if we're not already at position
            if (humanoidRootPart.Position - teleportPosition).Magnitude > 10 then
                -- Randomize method to avoid pattern detection
                local method = math.random(1, 3)

                if method == 1 then
                    physicsTeleport(teleportPosition)
                elseif method == 2 then
                    tweenTeleport(teleportPosition)
                else
                    networkTeleport(teleportPosition)
                end

                -- Small cooldown to prevent spam
                task.wait(0.5)
            end
        end
    end)
end

-- Toggle with RightShift
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.RightShift then
        isEnabled = not isEnabled

        if isEnabled then
            statusLabel.Text = "Instant TP: ON"
            statusLabel.TextColor3 = Color3.fromRGB(50, 255, 50)
            startChecking()
        else
            statusLabel.Text = "Instant TP: OFF"
            statusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            if checkConnection then
                checkConnection:Disconnect()
                checkConnection = nil
            end
        end
    end
end)

-- Character respawn handler
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    humanoidRootPart = newChar:WaitForChild("HumanoidRootPart")

    if isEnabled then
        startChecking()
    end
end)

