    if input.UserInputType == Enum.UserInputType.MouseButton2 then -- Right click
        teleportPosition = humanoidRootPart.Position
        statusLabel.Text = "Position Set!"
        task.wait(1)
        statusLabel.Text = isEnabled and "Instant TP: ON" or "Instant TP: OFF"
    end
end)

