-- XYZ Hub Instant Teleport (Carpet Method)
-- Made for stealth - uses physics-based teleportation

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- CONFIGURATION
local teleportPosition = Vector3.new(0, 100, 0) -- CHANGE THIS TO YOUR DESIRED POSITION
local carpetName = "Carpet" -- Name of the carpet tool
local teleportSpeed = 150 -- Speed that looks natural (not instant)

-- GUI Creation
