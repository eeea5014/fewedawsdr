local function showPopup(displayName, rarity)
	popTitle.Text = (rarity == "OG" or rarity == "Secret") and "High value!" or "Brainrot on server!"
	popDesc.Text = displayName .. " • " .. rarity
	popStroke.Color = rarityColor(rarity)
	popup.Visible = true
	popup.Position = UDim2.new(1, 20, 0, 20)
	local tweenIn = TweenService:Create(popup, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = UDim2.new(1, -316, 0, 20) })
	tweenIn:Play()
	task.delay(4, function()
		local tweenOut = TweenService:Create(popup, TweenInfo.new(0.2), { Position = UDim2.new(1, 20, 0, 20) })
		tweenOut:Play()
		tweenOut.Completed:Connect(function()
			popup.Visible = false
		end)
	end)
end

-- Background scan: task.wait (no Heartbeat = no FPS drop). Only runs on public servers.
local lastNotifyTime = 0
task.spawn(function()
	while true do
		task.wait(CHECK_INTERVAL)
		if isPrivateServer() then continue end
		local found = scanWorkspaceForBrainrots()
		if panelOpen then refreshBrainrotList() end
		if #found > 0 then
			local best = found[1]
			local now = tick()
			if best.order >= RARITY_ORDER.Secret and (now - lastNotifyTime) >= NOTIFY_COOLDOWN then
				lastNotifyTime = now
				showPopup(best.displayName, best.rarity)
			end
		end
	end
end)

print("[Steal a Brainrot Notifier] Loaded. Press J to see brainrots on this server.")
