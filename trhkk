-- Lightweight scan (GetChildren only, no GetDescendants = no FPS lag): only 2–3 levels with GetChildren (no GetDescendants = no FPS kill)
local function scanWorkspaceForBrainrots()
	local Workspace = game:GetService("Workspace")
	local seen = {}
	local found = {}

	local function addIfBrainrot(obj)
		local name = obj.Name
		if not name or name == "" then return end
		local key = name:lower():gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
		if seen[key] then return end
		local rarity = BRAINROT_TO_RARITY[key]
		if rarity then
			seen[key] = true
			table.insert(found, { displayName = name, rarity = rarity, order = RARITY_ORDER[rarity] or 0 })
		end
	end

	-- Level 1: direct children of Workspace
	for _, obj in ipairs(Workspace:GetChildren()) do
		addIfBrainrot(obj)
		if obj:IsA("Model") or obj:IsA("Folder") then
			-- Level 2
			for _, sub in ipairs(obj:GetChildren()) do
				addIfBrainrot(sub)
				-- Level 3 (e.g. bases with units inside)
				if (sub:IsA("Model") or sub:IsA("Folder")) and #sub:GetChildren() < 60 then
					for _, sub2 in ipairs(sub:GetChildren()) do
						addIfBrainrot(sub2)
					end
				end
			end
		end
	end

	table.sort(found, function(a, b) return a.order > b.order end)
	return found
end

