local function refreshBrainrotList()
	if isPrivateServer() then
		privateMsg.Visible = true
		scroll.Visible = false
		countLabel.Text = "Private server — join a public server to scan"
		for _, child in ipairs(scroll:GetChildren()) do
			if child:IsA("Frame") then child:Destroy() end
		end
		return
	end

	privateMsg.Visible = false
	scroll.Visible = true
	local found = scanWorkspaceForBrainrots()
	countLabel.Text = #found .. " brainrot" .. (#found == 1 and "" or "s") .. " on server"

	for _, child in ipairs(scroll:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	for i, data in ipairs(found) do
		local row = buildListEntry(data)
		row.LayoutOrder = i
		row.Parent = scroll
	end
end

