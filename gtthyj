end)

local ESPFolder, ServerESP
local serverPosition
local positionConn

local function ClearESP()
    if positionConn then
        positionConn:Disconnect()
        positionConn = nil
    end
    if ESPFolder then
        ESPFolder:Destroy()
        ESPFolder = nil
    end
    ServerESP = nil
end

local function CreateESPPart(name, color)
    local part = Instance.new("Part")
    part.Size = Vector3.new(4, 8, 4)
    part.Anchored = true
    part.CanCollide = false
    part.Material = Enum.Material.Neon
    part.Color = color
    part.Transparency = 0.3
    part.Parent = ESPFolder
    
    local highlight = Instance.new("Highlight", part)
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    
    return part
end

local function TrackServer(hrp)
    serverPosition = hrp.Position
    positionConn = hrp:GetPropertyChangedSignal("Position"):Connect(function()
        task.wait(0.15)
        if hrp then
            serverPosition = hrp.Position
            if ServerESP then
                ServerESP.CFrame = CFrame.new(serverPosition)
            end
        end
    end)
end

local function SetServerESP()
    ClearESP()
    ESPFolder = Instance.new("Folder", Workspace)
    ESPFolder.Name = "DesyncESP"
    
    ServerESP = CreateESPPart("SERVER POSITION", Color3.fromRGB(255, 0, 0))
    
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            TrackServer(hrp)
            ServerESP.CFrame = CFrame.new(serverPosition)
        end
    end
end

local function ApplyFFlags()
    local FFlags = {
        PhysicsSenderMaxBandwidthBps = "20000",
        WorldStepMax = "30",
        DisableDPIScale = "true",
        S2PhysicsSenderRate = "15000"
    }
    
    for name, value in pairs(FFlags) do
        pcall(function()
            sethiddenproperty(settings().Physics, name, tonumber(value) or value == "true")
        end)
    end
end

local function RespawnPlayer()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    if hum then
        hum:ChangeState(Enum.HumanoidStateType.Dead)
    end
    
    char:ClearAllChildren()
    local temp = Instance.new("Model", Workspace)
    LocalPlayer.Character = temp
    task.wait()
    LocalPlayer.Character = char
    temp:Destroy()
end

local function Desync()
    ApplyFFlags()
    RespawnPlayer()
    task.wait(0.6)
    SetServerESP()
    
    status.Text = "Status: Desync Active"
    desyncBtn.Text = "DESYNC ENABLED"
    desyncBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
end

desyncBtn.MouseButton1Click:Connect(function()
    Desync()
end)

