local speedBoosterEnabled = false
local speedBoosterConnection = nil

speedBtn.MouseButton1Click:Connect(function()
    speedBoosterEnabled = not speedBoosterEnabled
    
    if speedBoosterEnabled then
        speedBtn.Text = "SPEED: ON"
        speedBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        
        if speedBoosterConnection then
            speedBoosterConnection:Disconnect()
        end
        
        speedBoosterConnection = RunService.Heartbeat:Connect(function()
            local Char = LocalPlayer.Character
            if not Char then return end
            local HRP = Char:FindFirstChild("HumanoidRootPart")
            local Hum = Char:FindFirstChildOfClass("Humanoid")
            if not HRP or not Hum then return end
            
            local moveVector = Hum.MoveDirection
            if moveVector.Magnitude > 0.1 then
                local inputDirection = Vector3.new(moveVector.X, 0, moveVector.Z).Unit
                HRP.AssemblyLinearVelocity = Vector3.new(inputDirection.X * 28.5, HRP.AssemblyLinearVelocity.Y, inputDirection.Z * 28.5)
            else
                HRP.AssemblyLinearVelocity = Vector3.new(0, HRP.AssemblyLinearVelocity.Y, 0)
            end
        end)
    else
        speedBtn.Text = "SPEED BOOSTER"
        speedBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        
        if speedBoosterConnection then
            speedBoosterConnection:Disconnect()
            speedBoosterConnection = nil
        end
        
        local Char = LocalPlayer.Character
        if Char and Char:FindFirstChild("HumanoidRootPart") then
            Char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, Char.HumanoidRootPart.AssemblyLinearVelocity.Y, 0)
        end
    end
end)

