        Debris:AddItem(part, 30)
        objectCount = objectCount + 1
    end
end

-- Main lag loop
local function startLagging()
    lagging = true
    statusIcon.BackgroundColor3 = Color3.new(0, 1, 0)
    statusText.Text = "● LAGGING: ON (Intensity " .. intensity .. ")"
    
    -- Spawn multiple threads for different lag methods
    local threads = {}
    
    -- Thread 1: Part spawning (scales with intensity)
    table.insert(threads, spawn(function()
        while lagging do
            local partCount = intensity * 10
            spawnParts(partCount)
            wait(0.5 / intensity) -- Faster at higher intensity
        end
    end))
    
    -- Thread 2: Remote spam
    table.insert(threads, spawn(function()
        while lagging do
            local remoteCount = intensity * 5
            spamRemotes(remoteCount)
            wait(0.3 / intensity)
        end
    end))
    
    -- Thread 3: Physics objects (only at intensity >= 3)
    if intensity >= 3 then
        table.insert(threads, spawn(function()
            while lagging do
                spawnPhysicsObjects(intensity * 2)
                wait(0.4 / intensity)
            end
        end))
    end
    
    -- Thread 4: Notifications (intensity >= 2)
    if intensity >= 2 then
        table.insert(threads, spawn(function()
            while lagging do
                spamNotifications(intensity * 3)
                wait(0.5 / intensity)
            end
        end))
    end
    
    -- Thread 5: Teleport spam (intensity >= 4)
    if intensity >= 4 then
        table.insert(threads, spawn(function()
            while lagging do
                teleportSpam(intensity * 2)
                wait(0.4 / intensity)
            end
        end))
    end
    
    -- Thread 6: Mesh parts (intensity >= 5)
    if intensity >= 5 then
        table.insert(threads, spawn(function()
            while lagging do
                spawnMeshParts(intensity * 2)
                wait(0.6 / intensity)
            end
        end))
    end
    
    -- Store threads to stop later
    lagThreads = threads
end

local function stopLagging()
    lagging = false
    statusIcon.BackgroundColor3 = Color3.new(1, 0, 0)
    statusText.Text = "● LAGGING: OFF"
    
    -- Stop all threads
    for _, thread in ipairs(lagThreads) do
        coroutine.close(thread) -- In Lua, we can't easily kill threads; we rely on lagging flag
    end
    lagThreads = {}
    
    -- Optionally clear some objects? But they will expire via Debris.
end

