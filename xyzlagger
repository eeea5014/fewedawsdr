-- Method 1: Spawn invisible parts that replicate to others
local function spawnParts(amount)
    for i = 1, amount do
        local part = Instance.new("Part")
        part.Size = Vector3.new(math.random(5, 20), math.random(5, 20), math.random(5, 20))
        part.Position = Vector3.new(math.random(-500, 500), math.random(100, 300), math.random(-500, 500))
        part.Transparency = 1 -- Invisible to everyone, but still replicates
        part.Anchored = true
        part.CanCollide = false
        part.CastShadow = false
        part.Material = Enum.Material.SmoothPlastic
        part.Parent = Workspace
        Debris:AddItem(part, 30) -- Remove after 30 seconds to avoid memory leak
        objectCount = objectCount + 1
    end
end

-- Method 2: Spam remote events (generic attempts)
local function spamRemotes(amount)
    -- Attempt to find common remote names in Steal a Brainrot
    local possibleRemotes = {
        "TradeRequest", "BuyItem", "SellItem", "Attack", "UseItem",
        "CollectBrainrot", "PlaceTower", "Upgrade", "Spin", "OpenCrate",
        "RemoteEvent", "RemoteFunction", "Teleport", "Damage"
    }
    
    for i = 1, amount do
        for _, remoteName in ipairs(possibleRemotes) do
            local remote = ReplicatedStorage:FindFirstChild(remoteName) or 
                          game:GetService("ReplicatedStorage"):FindFirstChild(remoteName) or
                          player:FindFirstChild(remoteName)
            if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                pcall(function()
                    remote:FireServer("LagSpam" .. HttpService:GenerateGUID(false))
                end)
                packetCount = packetCount + 1
            end
        end
    end
end

-- Method 3: Create physics objects (unanchored) to stress server physics
local function spawnPhysicsObjects(amount)
    for i = 1, amount do
        local part = Instance.new("Part")
        part.Size = Vector3.new(2, 2, 2)
        part.Position = Vector3.new(math.random(-100, 100), 500, math.random(-100, 100))
        part.Transparency = 0.5 -- Semi-transparent so they're visible but not too obtrusive
        part.Anchored = false
        part.CanCollide = true
        part.Velocity = Vector3.new(math.random(-200, 200), math.random(-200, 200), math.random(-200, 200))
        part.RotVelocity = Vector3.new(math.random(-100, 100), math.random(-100, 100), math.random(-100, 100))
        part.Parent = Workspace
        Debris:AddItem(part, 20)
        objectCount = objectCount + 1
    end
end

-- Method 4: Spam GUI notifications (for all players, if possible)
local function spamNotifications(amount)
    -- Some games have a global notification system
    local notificationRemote = ReplicatedStorage:FindFirstChild("Notification") or
                               ReplicatedStorage:FindFirstChild("ShowNotification") or
                               ReplicatedStorage:FindFirstChild("ChatMessage")
    if notificationRemote and notificationRemote:IsA("RemoteEvent") then
        for i = 1, amount do
            pcall(function()
                notificationRemote:FireServer("LagSpam Notification " .. i)
            end)
            packetCount = packetCount + 1
        end
    end
end

-- Method 5: Teleport spam (if game has teleports)
local function teleportSpam(amount)
    local teleportRemote = ReplicatedStorage:FindFirstChild("Teleport") or
                          ReplicatedStorage:FindFirstChild("RequestTeleport")
    if teleportRemote and teleportRemote:IsA("RemoteEvent") then
        for i = 1, amount do
            pcall(function()
                teleportRemote:FireServer(Vector3.new(math.random(-1000,1000), math.random(0,500), math.random(-1000,1000)))
            end)
            packetCount = packetCount + 1
        end
    end
end

-- Method 6: Create many parts with complex meshes (if possible)
local function spawnMeshParts(amount)
    for i = 1, amount do
        local part = Instance.new("Part")
        part.Size = Vector3.new(10, 10, 10)
        part.Position = Vector3.new(math.random(-300, 300), math.random(50, 200), math.random(-300, 300))
        part.Transparency = 1
