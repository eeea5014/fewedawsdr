-- ==================== DRAG FUNCTIONALITY ====================

titleLabel.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = Vector2.new(mouse.X, mouse.Y)
		startPos = mainContainer.Position
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging then
		local delta = Vector2.new(mouse.X - dragStart.X, mouse.Y - dragStart.Y)
		mainContainer.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

-- ==================== FUNCTIONS ====================

-- Function to update current position label
local function updateCurrentPositionLabel()
	local pos = humanoidRootPart.Position
	setPositionLabel.Text = string.format("Current Position: X: %.1f | Y: %.1f | Z: %.1f", pos.X, pos.Y, pos.Z)
end

-- Function to update saved position label
local function updateSavedPositionLabel()
	savedPositionInfo.Text = string.format("Saved Position:\nX: %.1f | Y: %.1f | Z: %.1f", savedPosition.X, savedPosition.Y, savedPosition.Z)
end

-- Set Position Button Function
setPositionButton.MouseButton1Click:Connect(function()
	savedPosition = humanoidRootPart.Position
	updateSavedPositionLabel()
	setPositionButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
	wait(0.3)
	setPositionButton.BackgroundColor3 = Color3.fromRGB(50, 120, 50)
end)

-- Teleport Button Function
teleportButton.MouseButton1Click:Connect(function()
	if savedPosition ~= Vector3.new(0, 0, 0) then
		humanoidRootPart.CFrame = CFrame.new(savedPosition + Vector3.new(0, 3, 0))
		teleportButton.BackgroundColor3 = Color3.fromRGB(150, 200, 150)
		wait(0.3)
		teleportButton.BackgroundColor3 = Color3.fromRGB(100, 150, 200)
	else
		teleportButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
		wait(0.3)
		teleportButton.BackgroundColor3 = Color3.fromRGB(100, 150, 200)
	end
end)

