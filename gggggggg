	page1Content.Visible = false
	page2Content.Visible = true
	page1Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	page2Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
end)

-- Auto Grab Function (Toggle on click, auto teleports when E stops)
autoGrabButton.MouseButton1Click:Connect(function()
	autoGrabActive = not autoGrabActive
	
	if autoGrabActive then
		autoGrabButton.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
		autoGrabButton.Text = "AUTO GRAB ACTIVE - Click to STOP"
		
		-- Hold E key
		local eHeld = true
		while autoGrabActive and eHeld do
			game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E, false, game)
			wait(0.05)
		end
		
		-- Release E key
		game:GetService("VirtualInputManager"):SendKeyEvent(false, Enum.KeyCode.E, false, game)
		wait(0.1)
		
		-- Teleport to saved position automatically
		if savedPosition ~= Vector3.new(0, 0, 0) then
			humanoidRootPart.CFrame = CFrame.new(savedPosition + Vector3.new(0, 3, 0))
		end
		
		autoGrabActive = false
		autoGrabButton.BackgroundColor3 = Color3.fromRGB(200, 100, 100)
		autoGrabButton.Text = "Click to START holding E"
	end
end)

-- Update position every frame
RunService.RenderStepped:Connect(function()
	if humanoidRootPart then
		character = player.Character
		if character then
			humanoidRootPart = character:FindFirstChild("HumanoidRootPart") or humanoidRootPart
			updateCurrentPositionLabel()
		end
	end
end)

-- Handle character respawn
player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoidRootPart = character:WaitForChild("HumanoidRootPart")
end)

