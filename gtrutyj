--// Initialize GUI
local GUI = CreateGUI()

--// Game Logic
local CasesOpened = 0
local LastFreeCase = 0

--// Find Remote Events
local function GetRemotes()
    local remotes = {}
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            if name:find("open") or name:find("case") then
                remotes.OpenCase = v
            elseif name:find("sell") then
                remotes.SellItem = v
            elseif name:find("free") then
                remotes.FreeCase = v
            elseif name:find("battle") then
                remotes.JoinBattle = v
            end
        end
    end
    return remotes
end

local Remotes = GetRemotes()

--// UI Controller
local function UpdateUI()
    while GUI.ScreenGui.Parent do
        task.wait(0.5)
        
        --// Update Cash
        local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
        if leaderstats then
            local cash = leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money")
            if cash then
                GUI.CashLabel.Text = "💵 Cash: " .. tostring(cash.Value)
            end
        end
        
        --// Update Cases Opened Count
        GUI.CasesLabel.Text = "📦 Opened: " .. CasesOpened
        
        --// Update Status
        local status = "⏳ Waiting..."
        if CaseParadise.AutoOpen then
            status = "🎲 Opening " .. CaseParadise.SelectedCase .. "..."
        elseif CaseParadise.AutoSell then
            status = "💸 Selling items..."
        elseif CaseParadise.AutoFreeCase then
            status = "🎁 Checking free case..."
        end
        GUI.StatusLabel.Text = status
    end
end

--// Auto Open Cases
local function AutoOpenCases()
    while CaseParadise.Running do
        if CaseParadise.AutoOpen then
            local remote = Remotes.OpenCase
            if remote then
                --// Try to open case via remote
                pcall(function()
                    remote:FireServer(CaseParadise.SelectedCase)
                end)
                CasesOpened = CasesOpened + 1
            else
                --// Fallback: Simulate UI click
                local caseButton = PlayerGui:FindFirstChild("CaseButton", true) or PlayerGui:FindFirstChild("OpenCase", true)
                if caseButton then
                    VirtualInputManager:SendMouseButtonEvent(caseButton.AbsolutePosition.X + 50, caseButton.AbsolutePosition.Y + 25, 0, true, game, 0)
                    task.wait(0.1)
                    VirtualInputManager:SendMouseButtonEvent(caseButton.AbsolutePosition.X + 50, caseButton.AbsolutePosition.Y + 25, 0, false, game, 0)
                end
            end
            task.wait(CaseParadise.OpenDelay + math.random() * 0.5)
        else
            task.wait(0.5)
        end
    end
end

--// Auto Sell
local function AutoSell()
    while CaseParadise.Running do
        if CaseParadise.AutoSell then
            local remote = Remotes.SellItem
            if remote then
                --// Get inventory and sell low value items
                pcall(function()
                    remote:FireServer("SellDuplicates")
                end)
            end
            task.wait(5)
        else
            task.wait(1)
        end
    end
end

--// Auto Free Case
local function AutoFreeCase()
    while CaseParadise.Running do
        if CaseParadise.AutoFreeCase then
            local remote = Remotes.FreeCase
            if remote and (tick() - LastFreeCase) > 300 then -- 5 min cooldown
                pcall(function()
                    remote:FireServer()
                    LastFreeCase = tick()
                end)
            end
            task.wait(60)
        else
            task.wait(5)
        end
    end
end

--// Anti AFK
local function AntiAFK()
    local vu = game:GetService("VirtualUser")
    LocalPlayer.Idled:Connect(function()
        vu:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        vu:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    end)
end

