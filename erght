local function showNotification(text, duration)
	duration = duration or 5
	NotifyLabel.Text = text
	NotifyFrame.Visible = true
	NotifyFrame.Position = UDim2.new(0.5, -150, 0, -100)
	TweenService:Create(NotifyFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0.5, -150, 0, 20)}):Play()
	task.delay(duration, function()
		if NotifyFrame and NotifyFrame.Parent then
			TweenService:Create(NotifyFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0.5, -150, 0, -100)}):Play()
			task.wait(0.5)
			NotifyFrame.Visible = false
		end
	end)
end

