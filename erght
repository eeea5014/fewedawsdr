ToggleButton.MouseButton1Click:Connect(function()
	if isRunning then
		isRunning = false
		desyncSequence.isStopped = true
		StatusLabel.Text = "OFFLINE"
		StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
		ToggleButton.Text = "OFF"
		TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(220, 50, 50)}):Play()
		if desyncBox then desyncBox:Destroy() desyncBox = nil end
		resetCharacter()
	else
		isRunning = true
		StatusLabel.Text = "INITIALIZING..."
		StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
		ToggleButton.Text = "ON"
		TweenService:Create(ToggleButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 100)}):Play()
		showNotification("Desync starting in 12s", 5)
		createDesyncBox()
		runDesyncSequence()
		task.delay(12.57, function()
			if isRunning and StatusLabel then
				StatusLabel.Text = "DESYNC ACTIVE"
				StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
			end
		end)
	end
end)

local function updateSize()
	local size = Camera.ViewportSize
	if size.X < 600 then
		MainFrame.Size = UDim2.new(0, 300, 0, 180)
		MainFrame.Position = UDim2.new(0.5, -150, 0.5, -90)
	else
		MainFrame.Size = UDim2.new(0, 280, 0, 170)
		MainFrame.Position = UDim2.new(0.5, -140, 0.5, -85)
	end
end

RunService.Heartbeat:Connect(updateSize)
