-- Create podium function
local function createPodium(position, name)
    -- Remove existing podium
    local existing = Workspace:FindFirstChild(name)
    if existing then
        existing:Destroy()
    end
    
    -- Create platform
    local podium = Instance.new("Part")
    podium.Name = name
    podium.Parent = Workspace
    podium.Anchored = true
    podium.CanCollide = true
    podium.Size = Vector3.new(8, 1, 8)
    podium.Position = position + Vector3.new(0, -0.5, 0)
    podium.BrickColor = BrickColor.new("Bright blue")
    podium.Material = Enum.Material.Neon
    
    -- Create sign
    local sign = Instance.new("BillboardGui")
    sign.Name = "TeleportSign"
    sign.Parent = podium
    sign.Size = UDim2.new(0, 200, 0, 50)
    sign.StudsOffset = Vector3.new(0, 5, 0)
    
    local label = Instance.new("TextLabel")
    label.Parent = sign
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 0
    label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    label.BorderSizePixel = 0
    label.Font = Enum.Font.SourceSansBold
    label.Text = "TELEPORT HERE"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 16
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.TextStrokeTransparency = 0
    
    -- Add glow
    local light = Instance.new("PointLight")
    light.Parent = podium
    light.Color = Color3.fromRGB(100, 150, 255)
    light.Range = 20
    light.Brightness = 5
    
    return podium
end

-- Instant teleport function
local function instantTeleport(targetPos)
    if isTeleporting then return false
    
    local currentTime = tick()
    if currentTime - lastTeleport < Config.TeleportCooldown then
        return false
    end
    
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return false
    end
    
    local humanoidRootPart = character.HumanoidRootPart
    local currentPos = humanoidRootPart.Position
    local distance = (targetPos - currentPos).Magnitude
    
    -- Handle long distances
    if distance > Config.MaxDistance then
        local steps = math.ceil(distance / Config.MaxDistance)
        local direction = (targetPos - currentPos).Unit
        
        isTeleporting = true
        
        for i = 1, steps do
            local stepPos = currentPos + direction * (Config.MaxDistance * i)
            if i == steps then
                stepPos = targetPos
            end
            
            humanoidRootPart.CFrame = CFrame.new(stepPos)
            
            if i < steps then
                wait(0.05)
            end
        end
        
        isTeleporting = false
        lastTeleport = currentTime
        return true
    else
        -- Direct instant teleport
        isTeleporting = true
        humanoidRootPart.CFrame = CFrame.new(targetPos)
        isTeleporting = false
        lastTeleport = currentTime
        return true
    end
end

-- Setup dropdown functionality
local function setupDropdown(gui)
    local options = {
        "Podium 1 - Base 1",
        "Podium 2 - Base 2", 
        "Custom Teleport",
        "Custom Podium"
    }
    
    local currentSelection = 1
    local dropdownOpen = false
    
    local function updateDropdown()
        gui.DropdownButton.Text = options[currentSelection]
    end
    
    local function toggleDropdown()
        dropdownOpen = not dropdownOpen
        gui.Arrow.Text = dropdownOpen and "▲" or "▼"
        
        -- Clear existing options
        for _, child in pairs(gui.DropdownFrame:GetChildren()) do
            if child.Name:match("Option") then
                child:Destroy()
            end
        end
        
        if dropdownOpen then
            for i, option in ipairs(options) do
                local optionButton = Instance.new("TextButton")
                optionButton.Name = "Option" .. i
                optionButton.Parent = gui.DropdownFrame
                optionButton.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
                optionButton.BorderSizePixel = 0
                optionButton.Position = UDim2.new(0, 0, 0, i * 30)
                optionButton.Size = UDim2.new(1, 0, 0, 30)
                optionButton.Font = Enum.Font.SourceSans
                optionButton.Text = option
                optionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                optionButton.TextSize = 14
                optionButton.TextXAlignment = Enum.TextXAlignment.Left
                optionButton.ZIndex = 15
                
                optionButton.MouseButton1Click:Connect(function()
                    currentSelection = i
                    updateDropdown()
                    toggleDropdown()
                end)
                
                optionButton.MouseEnter:Connect(function()
                    optionButton.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
                end)
                
                optionButton.MouseLeave:Connect(function()
                    optionButton.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
                end)
            end
            
            gui.DropdownFrame.Size = UDim2.new(0, 200, 0, 30 + #options * 30)
        else
            gui.DropdownFrame.Size = UDim2.new(0, 200, 0, 30)
        end
    end
    
    gui.DropdownButton.MouseButton1Click:Connect(toggleDropdown)
    
    return function() return currentSelection end
end

-- Main initialization
local function initialize()
    print("Instant Steal TP: Starting initialization...")
    
    -- Create GUI
    local gui = createGUI()
    print("Instant Steal TP: GUI created")
    
    -- Setup dropdown
    local getSelection = setupDropdown(gui)
    print("Instant Steal TP: Dropdown setup complete")
    
    -- Teleport button handler
    gui.TeleportButton.MouseButton1Click:Connect(function()
        local selection = getSelection()
        local targetPos = nil
        
        if selection == 1 then
            targetPos = Config.BaseLocations[1]
        elseif selection == 2 then
            targetPos = Config.BaseLocations[2]
        elseif selection == 3 and customTeleportPos then
            targetPos = customTeleportPos
        elseif selection == 4 and podiumPos then
            targetPos = podiumPos
        end
        
        if targetPos then
            if instantTeleport(targetPos) then
                gui.TeleportButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                wait(0.5)
                gui.TeleportButton.BackgroundColor3 = Color3.fromRGB(50, 100, 255)
            else
                gui.TeleportButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
                wait(0.5)
                gui.TeleportButton.BackgroundColor3 = Color3.fromRGB(50, 100, 255)
            end
        end
    end)
    
    -- Set teleport button handler
    gui.SetTeleportButton.MouseButton1Click:Connect(function()
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            customTeleportPos = character.HumanoidRootPart.Position
            gui.SetTeleportButton.Text = "✓ Set!"
            gui.SetTeleportButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            wait(1)
            gui.SetTeleportButton.Text = "Set Teleport"
            gui.SetTeleportButton.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
        end
    end)
    
    -- Set podium button handler
    gui.SetPodiumButton.MouseButton1Click:Connect(function()
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            podiumPos = character.HumanoidRootPart.Position
            createPodium(podiumPos, "CustomPodium")
            gui.SetPodiumButton.Text = "✓ Created!"
            gui.SetPodiumButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            wait(1)
            gui.SetPodiumButton.Text = "Set Podium"
            gui.SetPodiumButton.BackgroundColor3 = Color3.fromRGB(255, 50, 100)
        end
    end)
    
    -- Create base podiums
    spawn(function()
        wait(0.5)
        createPodium(Config.BaseLocations[1], "Base1Podium")
        createPodium(Config.BaseLocations[2], "Base2Podium")
        print("Instant Steal TP: Base podiums created")
    end)
    
    print("Instant Steal TP: Initialization complete!")
    print("GUI should be visible now")
end

-- Start the script
spawn(function()
    -- Wait for player to be fully loaded
    player.CharacterAdded:Wait()
    wait(1)
    
    -- Initialize everything
    initialize()
end)

