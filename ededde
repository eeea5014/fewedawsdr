-- Function to update GUI
function updateGUI()
	if teleportPoint then
		statusLabel.Text = "✓ Point set | " .. string.format("(%.0f, %.0f, %.0f)", teleportPoint.X, teleportPoint.Y, teleportPoint.Z)
	else
		statusLabel.Text = "✗ No point set"
	end
end

-- Button interactions
setPointBtn.MouseButton1Click:Connect(function()
	setTeleportPoint()
end)

teleportBtn.MouseButton1Click:Connect(function()
	teleportToPoint()
end)

clearBtn.MouseButton1Click:Connect(function()
	teleportPoint = nil
	updateGUI()
end)

-- Hover effects
local function setupHoverEffect(button, originalColor)
	button.MouseEnter:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(
			math.min(originalColor.R + 0.2, 1) * 255,
			math.min(originalColor.G + 0.2, 1) * 255,
			math.min(originalColor.B + 0.2, 1) * 255
		)
	end)
	
	button.MouseLeave:Connect(function()
		button.BackgroundColor3 = originalColor
	end)
end

setupHoverEffect(setPointBtn, Color3.fromRGB(0, 120, 200))
setupHoverEffect(teleportBtn, Color3.fromRGB(0, 160, 100))
setupHoverEffect(clearBtn, Color3.fromRGB(100, 30, 30))

-- Keyboard shortcuts
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.E then
		setTeleportPoint()
	elseif input.KeyCode == Enum.KeyCode.R then
		teleportToPoint()
	end
end)

-- Update character reference when respawning
player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoidRootPart = character:WaitForChild("HumanoidRootPart")
	teleportPoint = nil
	updateGUI()
end)

updateGUI()
