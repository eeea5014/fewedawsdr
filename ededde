-- Teleport Script with Carpet & GUI
-- Place this as a LocalScript in StarterPlayer > StarterCharacterScripts

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Settings
local CARPET_NAME = "Carpet" -- Name of the carpet tool

local teleportPoint = nil

-- Function to check if player is holding carpet
local function isPlayerHoldingCarpet()
	local tool = player.Character:FindFirstChild(CARPET_NAME)
	return tool ~= nil and tool:IsA("Tool")
end

-- Function to set teleport point
local function setTeleportPoint()
	if isPlayerHoldingCarpet() then
		teleportPoint = humanoidRootPart.Position
		updateGUI()
	end
end

-- Function to teleport to point
local function teleportToPoint()
	if not isPlayerHoldingCarpet() then
		return
	end
	
	if teleportPoint == nil then
		return
	end
	
	humanoidRootPart.CFrame = CFrame.new(teleportPoint + Vector3.new(0, 3, 0))
end

