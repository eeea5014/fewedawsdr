-- Anti-cheat friendly teleport function (Instant)
local function safeTeleport(targetPosition)
    if isTeleporting then return false
    
    local currentTime = tick()
    if currentTime - lastTeleportTime < CONFIG.COOLDOWN_TIME then
        return false
    end
    
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return false
    end
    
    local humanoidRootPart = character.HumanoidRootPart
    local currentPosition = humanoidRootPart.Position
    local distance = (targetPosition - currentPosition).Magnitude
    
    -- Check distance limit
    if distance > CONFIG.MAX_DISTANCE then
        -- For long distances, teleport in steps but instantly
        local steps = math.ceil(distance / CONFIG.MAX_DISTANCE)
        local direction = (targetPosition - currentPosition).Unit
        
        isTeleporting = true
        
        for i = 1, steps do
            local stepPosition = currentPosition + direction * (CONFIG.MAX_DISTANCE * i)
            if i == steps then
                stepPosition = targetPosition
            end
            
            -- Instant teleport
            humanoidRootPart.CFrame = CFrame.new(stepPosition)
            
            -- Very small delay to prevent overwhelming
            if i < steps then
                wait(0.05)
            end
        end
        
        isTeleporting = false
        lastTeleportTime = currentTime
        return true
    else
        -- Direct instant teleport for short distances
        isTeleporting = true
        humanoidRootPart.CFrame = CFrame.new(targetPosition)
        isTeleporting = false
        lastTeleportTime = currentTime
        return true
    end
end

-- Create podium function
local function createPodium(position, name)
    -- Remove existing podium with same name
    local existingPodium = Workspace:FindFirstChild(name)
    if existingPodium then
        existingPodium:Destroy()
    end
    
    -- Create podium platform
    local podium = Instance.new("Part")
    podium.Name = name
    podium.Parent = Workspace
    podium.Anchored = true
    podium.CanCollide = true
    podium.Size = Vector3.new(8, 1, 8)
    podium.Position = position + Vector3.new(0, -0.5, 0)
    podium.BrickColor = BrickColor.new("Bright blue")
    podium.Material = Enum.Material.Neon
    
    -- Create teleport sign
    local sign = Instance.new("BillboardGui")
    sign.Name = "TeleportSign"
    sign.Parent = podium
    sign.Size = UDim2.new(0, 200, 0, 50)
    sign.StudsOffset = Vector3.new(0, 5, 0)
    
    local label = Instance.new("TextLabel")
    label.Parent = sign
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 0
    label.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    label.BorderSizePixel = 0
    label.Font = Enum.Font.SourceSansBold
    label.Text = "TELEPORT HERE"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 16
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.TextStrokeTransparency = 0
    
    -- Add glow effect
    local glow = Instance.new("PointLight")
    glow.Parent = podium
    glow.Color = Color3.fromRGB(100, 150, 255)
    glow.Range = 20
    glow.Brightness = 5
    
    return podium
end

-- Dropdown functionality
local function updateDropdownText()
    dropdownButton.Text = podiumOptions[currentSelection]
end

local function toggleDropdown()
    dropdownOpen = not dropdownOpen
    arrow.Text = dropdownOpen and "▲" or "▼"
    
    -- Clear existing options
    for _, child in pairs(dropdownFrame:GetChildren()) do
        if child.Name:match("Option") then
            child:Destroy()
        end
    end
    
    if dropdownOpen then
        for i, option in ipairs(podiumOptions) do
            local optionButton = Instance.new("TextButton")
            optionButton.Name = "Option" .. i
            optionButton.Parent = dropdownFrame
            optionButton.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            optionButton.BorderSizePixel = 0
            optionButton.Position = UDim2.new(0, 0, 0, i * 30)
            optionButton.Size = UDim2.new(1, 0, 0, 30)
            optionButton.Font = Enum.Font.SourceSans
            optionButton.Text = option
            optionButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            optionButton.TextSize = 14
            optionButton.TextXAlignment = Enum.TextXAlignment.Left
            optionButton.Visible = true
            
            optionButton.MouseButton1Click:Connect(function()
                currentSelection = i
                updateDropdownText()
                toggleDropdown()
            end)
            
            optionButton.MouseEnter:Connect(function()
                optionButton.BackgroundColor3 = Color3.fromRGB(70, 70, 80)
            end)
            
            optionButton.MouseLeave:Connect(function()
                optionButton.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            end)
        end
        
        dropdownFrame.Size = UDim2.new(0, 200, 0, 30 + #podiumOptions * 30)
    else
        dropdownFrame.Size = UDim2.new(0, 200, 0, 30)
    end
end

