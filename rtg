-- Função para criar e atualizar plataforma do 3rd Floor
local function updateThirdFloor()
    if not thirdFloorEnabled or not hrp or not hrp.Parent then
        if thirdFloorPlatform then
            thirdFloorPlatform:Destroy()
            thirdFloorPlatform = nil
        end
        return
    end
    
    -- Criar ou atualizar plataforma
    if not thirdFloorPlatform then
        thirdFloorPlatform = Instance.new("Part")
        thirdFloorPlatform.Name = "SMARTSCRIPT_3rdFloor"
        thirdFloorPlatform.Size = Vector3.new(15, 1, 15) -- Tamanho maior
        thirdFloorPlatform.Transparency = 0.5
        thirdFloorPlatform.Color = Color3.fromRGB(0, 170, 255) -- Azul SmartScript
        thirdFloorPlatform.Material = Enum.Material.Neon
        thirdFloorPlatform.Anchored = true
        thirdFloorPlatform.CanCollide = true
        thirdFloorPlatform.CastShadow = false
        thirdFloorPlatform.Parent = workspace
    end
    
    -- Posicionar plataforma 3 studs abaixo do HRP
    local targetPosition = hrp.Position - Vector3.new(0, 3, 0)
    thirdFloorPlatform.Position = Vector3.new(targetPosition.X, targetPosition.Y, targetPosition.Z)
    
    -- Tornar partes dentro de "Plots" transparentes
    transparencyParts = {}
    
    -- Procurar por pastas chamadas "Plots" no workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name:lower() == "plots" and obj:IsA("Folder") then
            -- Processar todos os descendentes da pasta Plots
            for _, plotObj in pairs(obj:GetDescendants()) do
                if plotObj:IsA("BasePart") then
                    -- Salvar transparência original
                    if not transparencyParts[plotObj] then
                        transparencyParts[plotObj] = plotObj.Transparency
                    end
                    -- Aplicar transparência 0.5
                    plotObj.Transparency = 0.5
                end
            end
        end
    end
    
    -- Aplicar transparência também a Decals e Textures dentro de Plots
    for _, obj in pairs(workspace:GetDescendants()) do
        if (obj:IsA("Decal") or obj:IsA("Texture")) and obj.Parent then
            -- Verificar se o parente está em um Plot
            local parent = obj.Parent
            while parent and parent ~= workspace do
                if parent.Name:lower() == "plots" then
                    if not transparencyParts[obj] then
                        transparencyParts[obj] = obj.Transparency
                    end
                    obj.Transparency = 0.5
                    break
                end
                parent = parent.Parent
            end
        end
    end
end

-- Função para limpar transparência quando 3rd Floor for desativado
local function cleanupThirdFloor()
    if thirdFloorPlatform then
        thirdFloorPlatform:Destroy()
        thirdFloorPlatform = nil
    end
    
    -- Restaurar transparência original das partes
    for obj, originalTransparency in pairs(transparencyParts) do
        if obj and obj.Parent then
            pcall(function()
                obj.Transparency = originalTransparency
            end)
        end
    end
    
    transparencyParts = {}
    
    if thirdFloorConnection then
        thirdFloorConnection:Disconnect()
        thirdFloorConnection = nil
    end
end

-- Sistema de movimento personalizado
local function customMovement()
    -- Desconectar conexão anterior se existir
    if moveConnection then
        moveConnection:Disconnect()
        moveConnection = nil
    end
    
    if speedEnabled then
        -- Criar nova conexão que continua indefinidamente
        moveConnection = RunService.Heartbeat:Connect(function()
            if humanoid and hrp and humanoid.MoveDirection.Magnitude > 0 then
                local moveDir = humanoid.MoveDirection
                -- Speed de 28.3 usando Velocity
                local newVelocity = Vector3.new(moveDir.X * 28.3, hrp.Velocity.Y, moveDir.Z * 28.3)
                hrp.AssemblyLinearVelocity = newVelocity
            end
        end)
    end
end

-- Sistema de detecção de ProximityPrompt
local function setupProximityPromptDetection()
    local connection
    
    connection = ProximityPromptService.PromptButtonHoldEnded:Connect(function(prompt, playerWhoTriggered)
        if playerWhoTriggered == player and fullInvisEnabled and not isProcessing then
            isProcessing = true
            
            -- Atualizar referências do personagem
            character = player.Character or player.CharacterAdded:Wait()
            humanoid = character:WaitForChild("Humanoid")
            hrp = character:WaitForChild("HumanoidRootPart")
            
            -- 1. Fazer partes caírem com física (sem Motor6D/Ragdoll)
            local welds = makePartsFall()
            
            -- 2. Após 2 segundos, tornar partes sem colisão do MAPA invisíveis PERMANENTEMENTE
            task.wait(2)
            makePartsInvisible(welds)
            
            -- 3. Após 3 segundos adicionais (total 5s), restaurar humanoid
            task.wait(3)
            restoreHumanoid()
            
            isProcessing = false
        end
    end)
    
    return connection
end

