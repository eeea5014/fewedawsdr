--// 5. Toggle Logic

local Toggled = false

ToggleButton.MouseButton1Click:Connect(function()

    Toggled = not Toggled -- Switch State

    if Toggled then

        --// TURN ON

        ToggleButton.Text = "DESYNC: ON"

        ToggleButton.BackgroundColor3 = Color3.fromRGB(60, 180, 90) -- Green

        

        local Character = LocalPlayer.Character

        if not Character then return end

        

        local HRP = Character:FindFirstChild("HumanoidRootPart")

        local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")

        if HRP and Humanoid then

            -- 1. Apply Desync Offset (Breaking Interpolation)

            -- We use * 900 as hinted in the decompiled comments to ensure the distance breaks server interpolation

            HRP.CFrame = HRP.CFrame - (HRP.CFrame.RightVector * 900) 

            task.wait(0.05)

            HRP.CFrame = HRP.CFrame - (HRP.CFrame.RightVector * 900)

            task.wait(0.05)

            -- 2. Apply FFlags

            for _, flag in ipairs(FFlags) do

                safe_setfflag(flag[1], flag[2])

            end

            -- 3. Force State Update

            Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

            task.wait(0.1)

            Humanoid:ChangeState(Enum.HumanoidStateType.Landed)

            -- 4. Flicker Network Ownership (The core desync method)

            pcall(function()

                HRP:SetNetworkOwner(nil) -- Give to Server

                task.wait(0.05)

                HRP:SetNetworkOwner(LocalPlayer) -- Take back to Client

            end)

        end

        

    else

        --// TURN OFF

        ToggleButton.Text = "DESYNC: OFF"

        ToggleButton.BackgroundColor3 = Color3.fromRGB(180, 60, 60) -- Red

        

        -- Optional: Reset Network Owner to client to ensure stability when off

        local Character = LocalPlayer.Character

        if Character and Character:FindFirstChild("HumanoidRootPart") then

            pcall(function()

                Character.HumanoidRootPart:SetNetworkOwner(LocalPlayer)

            end)

        end

    end

end)
