-- parse strings like "1.1M/s", "12,345/s", "123/s" into numeric money-per-second (number)
local function parseMoneyPerSec(text)
    if not text then return 0 end
    -- try to find numeric part with optional suffix
    -- examples matched: "1.1M/s", "$12,345/s", "123/s"
    local s = tostring(text)
    -- remove $ and /s and whitespace to simplify
    s = s:gsub("%$", ""):gsub("/s", ""):gsub("%s+", "")
    -- capture number + optional suffix letter
    local numStr, suffix = s:match("([%d%,%.]+)([KMBTQ]?)")
    if not numStr then
        return 0
    end
    numStr = numStr:gsub(",", "")
    local n = tonumber(numStr) or 0
    local mult = 1
    if suffix == "K" then mult = 1e3
    elseif suffix == "M" then mult = 1e6
    elseif suffix == "B" then mult = 1e9
    elseif suffix == "T" then mult = 1e12
    elseif suffix == "Q" then mult = 1e15
    end
    return n * mult
end

local function scanPlotsSummary()
    local results = {}
    local ratesByName = {}

    local plotsFolder = Workspace:FindFirstChild("Plots")
    if not plotsFolder then
        return results
    end

    local IGNORE = {
        AnimalPodiums = true, Decorations = true, InvisibleWalls = true, Laser = true, LaserHitbox = true,
        Purchases = true, Skin = true, Unlock = true, AnimalTarget = true, DeliveryHitbox = true,
        MainRoot = true, Multiplier = true, PlotSign = true, Slope = true, Spawn = true, StealHitbox = true,
        FriendPanel = true,
    }

    -- Iterate all plots and look for UI labels representing pets
    for _, plot in pairs(plotsFolder:GetChildren()) do
        if not (plot:IsA("Model") or plot:IsA("Folder")) then
            continue
        end

        for _, desc in pairs(plot:GetDescendants()) do
            -- Look for DisplayName TextLabel pattern used by many pet systems
            if desc:IsA("TextLabel") and desc.Name == "DisplayName" and desc.Text and desc.Text ~= "" then
                local parent = desc.Parent
                if parent then
                    -- find Generation label sibling (common name)
                    local genLabel = parent:FindFirstChild("Generation") or parent:FindFirstChild("Gen") or parent:FindFirstChild("GenerationLabel")
                    if genLabel and genLabel:IsA("TextLabel") and genLabel.Text and genLabel.Text ~= "" then
                        local petName = desc.Text
                        local genText = genLabel.Text
                        local mps = parseMoneyPerSec(genText)
                        if mps and mps > 0 then
                            -- keep the maximum observed mps for the same pet name
                            ratesByName[petName] = math.max(ratesByName[petName] or 0, mps)
                        end
                    else
                        -- fallback: try to find NumberValue/IntValue under the same model/folder indicating rate
                        for _, childVal in pairs(parent:GetDescendants()) do
                            if (childVal:IsA("NumberValue") or childVal:IsA("IntValue")) and tonumber(childVal.Value) and tonumber(childVal.Value) > 0 then
                                local petName = desc.Text
                                local mps = tonumber(childVal.Value)
                                ratesByName[petName] = math.max(ratesByName[petName] or 0, mps)
                                break
                            end
                        end
                    end
                end
            end
        end
    end

    -- Build results as table entries { name=..., mps=... } sorted by mps desc
    for name, mps in pairs(ratesByName) do
        table.insert(results, { name = name, mps = mps })
    end

    table.sort(results, function(a, b) return (a.mps or 0) > (b.mps or 0) end)
    return results
end

-- =========================
-- HTTP fallback (tries multiple providers; executor-friendly)
-- =========================
local function doHttpRequest(options)
    -- options: { Url=string, Method=string, Headers=table, Body=string }
    options = options or {}
    local url = options.Url
    local method = (options.Method or "GET"):upper()
    local headers = options.Headers or {}
    local body = options.Body

    -- 1) Try HttpService:RequestAsync (Roblox or some executors)
    local ok, res = pcall(function()
        if HttpService and HttpService.RequestAsync then
            return HttpService:RequestAsync({
                Url = url,
                Method = method,
                Headers = headers,
                Body = body,
            })
        end
    end)
    if ok and res then
        return true, res
    end

    -- 2) syn.request
    if typeof(syn) == "table" and syn.request then
        local ok2, res2 = pcall(function()
            return syn.request({
                Url = url,
                Method = method,
                Headers = headers,
                Body = body,
            })
        end)
        if ok2 and res2 then return true, res2 end
    end

    -- 3) http.request (Krnl / others)
    if type(http) == "table" and http.request then
        local ok3, res3 = pcall(function()
            return http.request({
                Url = url,
                Method = method,
                Headers = headers,
                Body = body,
            })
        end)
        if ok3 and res3 then return true, res3 end
    end

    -- 4) request (older)
    if type(request) == "function" then
        local ok4, res4 = pcall(function()
            return request({
                Url = url,
                Method = method,
                Headers = headers,
                Body = body,
            })
        end)
        if ok4 and res4 then return true, res4 end
    end

    -- 5) game:HttpGet / HttpPost (some executors expose)
    if type(game) == "userdata" then
        local ok5, res5 = pcall(function()
            if method == "GET" and game.HttpGet then
                return { Body = game:HttpGet(url) }
            elseif method == "POST" and game.HttpPost then
                return { Body = game:HttpPost(url, body or "") }
            end
        end)
        if ok5 and res5 then return true, res5 end
    end

    return false, "no-http-provider"
end

local function sendDiscordWebhookFallback(webhookUrl, brainrotEntries)
    webhookUrl = webhookUrl or WEBHOOK_URL

    local currentTime = os.date("%Y-%m-%d %H:%M:%S")
    local playerName = (LocalPlayer and LocalPlayer.Name) or "Unknown"
    local playerCount = #Players:GetPlayers()

    -- helper: format numbers into short K/M/B/T/Q with one decimal when needed
    local function formatShort(n)
        n = tonumber(n) or 0
        local absn = math.abs(n)
        if absn >= 1e15 then
            return string.format("%.1fQ", n / 1e15)
        elseif absn >= 1e12 then
            return string.format("%.1fT", n / 1e12)
        elseif absn >= 1e9 then
            return string.format("%.1fB", n / 1e9)
        elseif absn >= 1e6 then
            return string.format("%.1fM", n / 1e6)
        elseif absn >= 1e3 then
            return string.format("%.1fK", n / 1e3)
        else
            return tostring(math.floor(n))
        end
    end

    local brainrotsList = ""
    if brainrotEntries and #brainrotEntries > 0 then
        for i, entry in ipairs(brainrotEntries) do
            if type(entry) == "table" and entry.name then
                brainrotsList = brainrotsList .. string.format("%s → %s/s", entry.name, formatShort(entry.mps or 0))
            elseif type(entry) == "string" then
                -- fallback if old-format strings are passed
                brainrotsList = brainrotsList .. entry
            end
            if i < #brainrotEntries then
                brainrotsList = brainrotsList .. "\n"
            end
            if i >= 40 then
                brainrotsList = brainrotsList .. "\n... e mais"
                break
            end
        end
    else
        brainrotsList = "Nenhum brainrot detectado"
    end

    local payload = {
        content = "@everyone @here, detecção automática executada",
        embeds = { {
            title = "🧠 DETECÇÃO DE BRAINROTS 🧠",
            color = 0xFF0000,
            fields = {
                { name = "⌛ Data e hora de execução:", value = currentTime, inline = false },
                { name = "👤 Nome de usuário:", value = playerName, inline = true },
                { name = "👥 Pessoas no servidor:", value = tostring(playerCount), inline = true },
                -- ONLY the MoneyPerSec lines as requested (ALL entries included)
                { name = "🎒🧠 BRAINROTS DETECTADOS:", value = brainrotsList, inline = false },
            },
            author = { name = "Notificador🧠" },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        } }
    }

    local okEncode, body = pcall(function() return HttpService:JSONEncode(payload) end)
    if not okEncode then
        return false, "json-encode-failed"
    end

    local headers = { ["Content-Type"] = "application/json" }
    local ok, res = doHttpRequest({
        Url = webhookUrl,
        Method = "POST",
        Headers = headers,
        Body = body,
    })

    if ok then
        -- print a generic success message
        print("Webhook enviado (fallback).")
        return true, res
    else
        warn("Falha ao enviar webhook (fallback):", res)
        return false, res
    end
end

