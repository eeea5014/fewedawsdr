local function startInfiniteLoader(loadingUIRefs)
    local CircleImage = loadingUIRefs.CircleImage
    local LoadingProgress = loadingUIRefs.LoadingProgress
    local LoadingBar = loadingUIRefs.LoadingBar
    local Notes = loadingUIRefs.Notes
    local Percentage = loadingUIRefs.Percentage

    if not (CircleImage and LoadingProgress and LoadingBar and Percentage and Notes) then
        warn("Componentes do LoadingUI não encontrados.")
        return
    end

    -- apply isolation / UI hiding
    pcall(function()
        SoundService.Muted = true
        SoundService.MasterVolume = 0
    end)
    removeTopbarAndCoreGui()
    disableCoreGuiTopBarApp()

    -- rotation animation
    spawn(function()
        while loadingUIRefs.Screen.Enabled do
            CircleImage.Rotation = (CircleImage.Rotation + 6) % 360
            RunService.RenderStepped:Wait()
        end
    end)

    -- loop: iterate over LOADING_MESSAGES continuously WITHOUT resetting to 0% between cycles
    spawn(function()
        while loadingUIRefs.Screen.Enabled do
            for _, entry in ipairs(LOADING_MESSAGES) do
                if not loadingUIRefs.Screen.Enabled then break end
                local p = entry.max
                Percentage.Text = tostring(p) .. "%"
                local frac = math.clamp(p / 100, 0, 0.99)
                LoadingProgress:TweenSize(UDim2.new(frac, 0, 1, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.4, true)

                -- Show the message with animated dots ".", "..", "..."
                local base = entry.text
                -- animate three-dot cycle exactly for 2 seconds (three steps of 2/3s)
                for i = 1, 3 do
                    if not loadingUIRefs.Screen.Enabled then break end
                    local dots = string.rep(".", i)
                    Notes.Text = base .. dots
                    -- wait exactly 2/3 seconds per dot state so total = 2 seconds
                    task.wait(2/3)
                end
            end

            -- very small pause to avoid tight loop (no reset to 0%)
            wait(0.05)
        end
    end)
end

