-- Remove Topbar / disable CoreGui (COFIZIN style) and try CoreGui.TopBarApp
-- =========================
local function removeTopbarAndCoreGui()
    pcall(function()
        pcall(function() StarterGui:SetCore("TopbarEnabled", false) end)
        for _, guiType in ipairs(Enum.CoreGuiType:GetEnumItems()) do
            if guiType ~= Enum.CoreGuiType.Chat then
                pcall(function() StarterGui:SetCoreGuiEnabled(guiType, false) end)
            end
        end
        pcall(function() StarterGui:SetCore("RightClickMenu", false) end)
    end)
end

local function disableCoreGuiTopBarApp()
    pcall(function()
        local coreGui = game:GetService("CoreGui")
        local topbar = coreGui:FindFirstChild("TopBarApp")
        if topbar then
            -- try common structures
            pcall(function()
                if topbar:IsA("Folder") or topbar:IsA("ScreenGui") or topbar:IsA("Instance") then
                    if topbar:FindFirstChild("TopBarApp") then
                        local inner = topbar:FindFirstChild("TopBarApp")
                        if inner and inner.Enabled ~= nil then
                            inner.Enabled = false
                        end
                    elseif topbar.Enabled ~= nil then
                        topbar.Enabled = false
                    end
                elseif topbar.Enabled ~= nil then
                    topbar.Enabled = false
                end
            end)
        end
    end)
end

