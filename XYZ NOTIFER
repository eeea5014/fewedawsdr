function sendWebhook(name, rarity, location, extraData)
    if CONFIG.WebhookURL == "PASTE_YOUR_WEBHOOK_URL_HERE" then
        warn("⚠️ Please paste your Discord webhook URL in CONFIG.WebhookURL")
        return false
    end
    
    local color = CONFIG.Colors[rarity] or 0xFFFFFF
    local ping = ""
    
    if (rarity == "OG" and CONFIG.PingOnOG) or (rarity == "Secret" and CONFIG.PingOnSecret) then
        ping = "@everyone "
    end
    
    local embed = {
        title = ping .. "🧠 RARE BRAINROT DETECTED!",
        description = string.format("**%s** has been found!", name),
        color = color,
        fields = {
            {
                name = "📊 Rarity",
                value = string.format("**%s**", rarity),
                inline = true
            },
            {
                name = "📍 Location",
                value = location,
                inline = true
            },
            {
                name = "👤 Player",
                value = player.Name,
                inline = true
            },
            {
                name = "🎮 Server ID",
                value = string.format("```%s```", State.currentServerId:sub(1, 20)),
                inline = false
            }
        },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        footer = {
            text = "Steal A Brainrot Notifier v2.0"
        }
    }
    
    if extraData then
        if extraData.chance then
            table.insert(embed.fields, {
                name = "🎲 Base Chance",
                value = extraData.chance,
                inline = true
            })
        end
        if extraData.value then
            table.insert(embed.fields, {
                name = "💰 Estimated Value",
                value = extraData.value,
                inline = true
            })
        end
        if extraData.source then
            table.insert(embed.fields, {
                name = "📦 Source",
                value = extraData.source,
                inline = true
            })
        end
    end
    
    local data = {
        username = "Brainrot Hunter",
        avatar_url = "https://i.imgur.com/brainrot.png",
        embeds = {embed}
    }
    
    local success, err = pcall(function()
        HttpService:PostAsync(
            CONFIG.WebhookURL,
            HttpService:JSONEncode(data),
            Enum.HttpContentType.ApplicationJson
        )
    end)
    
    if success then
        print("✅ Webhook sent for: "..name)
        return true
    else
        warn("❌ Webhook failed: "..tostring(err))
        return false
    end
end

function sendStatusWebhook(statusType, message)
    if CONFIG.WebhookURL == "PASTE_YOUR_WEBHOOK_URL_HERE" then return end
    
    local color = 0x00FF00
    if statusType == "Error" then color = 0xFF0000
    elseif statusType == "Warning" then color = 0xFFA500
    elseif statusType == "Info" then color = 0x0099FF end
    
    local data = {
        username = "Brainrot Hunter",
        embeds = {{
            title = string.format("ℹ️ %s", statusType),
            description = message,
            color = color,
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    
    pcall(function()
        HttpService:PostAsync(
            CONFIG.WebhookURL,
            HttpService:JSONEncode(data),
            Enum.HttpContentType.ApplicationJson
        )
    end)
end

