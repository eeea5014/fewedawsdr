function detectBrainrot(name, location, owner)
    local info = BRAINROT_LOOKUP[name]
    if not info then return end
    
    local rarity = info.rarity
    
    -- Check if priority is enabled
    if not CONFIG.Priority[rarity] then return end
    
    -- Cooldown check
    local key = name.."_"..location
    local lastNotified = State.notificationHistory[key]
    if lastNotified and (os.time() - lastNotified) < CONFIG.NotificationCooldown then
        return
    end
    State.notificationHistory[key] = os.time()
    
    -- Update stats
    State.stats.found = State.stats.found + 1
    if rarity == "OG" then State.stats.ogFound = State.stats.ogFound + 1 end
    if rarity == "Secret" then State.stats.secretFound = State.stats.secretFound + 1 end
    
    -- Build location string
    local locStr = location
    if owner then
        locStr = string.format("%s (Owner: %s)", location, owner)
    end
    
    -- Send webhook
    if CONFIG.AutoNotify then
        sendWebhook(name, rarity, locStr, info.data)
    end
    
    -- Create GUI notification
    createGUINotification(name, rarity, locStr)
    
    -- Auto-join logic for OG/Secret
    if rarity == "OG" or rarity == "Secret" then
        print(string.format("🚨 ULTRA RARE: %s found at %s!", name, locStr))
        -- Could add auto-teleport here if you want
    end
end

function scanWorkspace()
    local workspace = game:GetService("Workspace")
    
    -- Scan 1: Conveyor Belt (Public Spawns)
    local conveyor = workspace:FindFirstChild("Conveyor") 
        or workspace:FindFirstChild("ConveyorBelt")
        or workspace:FindFirstChild("Conveyor")
        or workspace:FindFirstChild("Belt")
    
    if conveyor then
        for _, obj in pairs(conveyor:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("MeshPart") then
                local name = obj.Name
                detectBrainrot(name, "Conveyor Belt", nil)
                
                -- Check for nametags/billboards
                for _, child in pairs(obj:GetDescendants()) do
                    if child:IsA("BillboardGui") or child:IsA("TextLabel") then
                        if child.Text and #child.Text > 0 then
                            detectBrainrot(child.Text, "Conveyor Belt", nil)
                        end
                    end
                end
            end
        end
    end
    
    -- Scan 2: Player Bases (Other Players' Collections)
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            -- Look for base folder
            local baseNames = {
                otherPlayer.Name.."_Base",
                otherPlayer.Name.."_Plot",
                otherPlayer.Name.."_Island",
                otherPlayer.Name
            }
            
            for _, baseName in pairs(baseNames) do
                local base = workspace:FindFirstChild(baseName)
                if base then
                    for _, obj in pairs(base:GetDescendants()) do
                        if obj:IsA("Model") or obj:IsA("Part") then
                            detectBrainrot(obj.Name, string.format("%s's Base", otherPlayer.Name), otherPlayer.Name)
                        end
                    end
                end
            end
            
            -- Scan character
            local char = otherPlayer.Character
            if char then
                for _, obj in pairs(char:GetDescendants()) do
                    if obj:IsA("Tool") or obj:IsA("Model") then
                        detectBrainrot(obj.Name, string.format("%s's Inventory", otherPlayer.Name), otherPlayer.Name)
                    end
                end
            end
        end
    end
    
    -- Scan 3: ReplicatedStorage (Server Storage)
    local rs = game:GetService("ReplicatedStorage")
    for _, obj in pairs(rs:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Folder") then
            detectBrainrot(obj.Name, "Server Storage", "Server")
        end
    end
    
    -- Scan 4: Active Brainrots Folder (if exists)
    local activeFolder = workspace:FindFirstChild("ActiveBrainrots") 
        or workspace:FindFirstChild("Spawns")
        or workspace:FindFirstChild("Items")
    
    if activeFolder then
        for _, obj in pairs(activeFolder:GetChildren()) do
            detectBrainrot(obj.Name, "Active Spawns", nil)
        end
    end
end

