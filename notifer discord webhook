-- ═══════════════════════════════════════════════════════════════

local function updateStatus()
    local runtime = os.time() - startTime
    local mins = math.floor(runtime / 60)
    local secs = runtime % 60
    
    local statusText = string.format(
        "Status: RUNNING\n" ..
        "Runtime: %02d:%02d\n" ..
        "Found: %d brainrots\n" ..
        "Webhook: %s",
        mins, secs,
        totalFound,
        WEBHOOK_URL ~= "PASTE_YOUR_DISCORD_WEBHOOK_HERE" and "✅ Active" or "❌ Not Set"
    )
    
    GUI.Status.Text = statusText
end

local function mainLoop()
    while true do
        local found = scanForBrainrots()
        
        for _, item in ipairs(found) do
            local key = item.name .. "_" .. item.location
            
            -- Check cooldown
            if not lastNotification[key] or (os.time() - lastNotification[key]) > COOLDOWN then
                lastNotification[key] = os.time()
                totalFound = totalFound + 1
                
                -- Send webhook
                sendWebhook(item.name, item.rarity, item.location)
                
                -- Update GUI
                GUI.LastFound.Text = string.format("Last: %s (%s) at %s", 
                    item.name, item.rarity, item.location)
                GUI.LastFound.TextColor3 = Color3.fromRGB(0, 255, 0)
                
                print(string.format("🧠 Found: %s (%s) at %s", 
                    item.name, item.rarity, item.location))
            end
        end
        
        updateStatus()
        wait(CHECK_DELAY)
    end
end

