local function sendWebhook(name, rarity, location)
    if WEBHOOK_URL == "PASTE_YOUR_DISCORD_WEBHOOK_HERE" then
        warn("⚠️ Please set your webhook URL!")
        return false
    end
    
    local color = RARITY_COLORS[rarity] or 0xFFFFFF
    local ping = (rarity == "OG" or rarity == "Secret") and "@everyone " or ""
    
    local data = {
        content = ping .. "🧠 **" .. name .. "** detected!",
        embeds = {{
            title = "Brainrot Found in Public Server",
            description = string.format("**%s** (%s)", name, rarity),
            color = color,
            fields = {
                {name = "📍 Location", value = location, inline = true},
                {name = "👤 Found By", value = player.Name, inline = true},
                {name = "⏰ Time", value = os.date("%H:%M:%S"), inline = true}
            },
            footer = {text = "Steal A Brainrot Scanner"}
        }}
    }
    
    local success, err = pcall(function()
        HttpService:PostAsync(
            WEBHOOK_URL,
            HttpService:JSONEncode(data),
            Enum.HttpContentType.ApplicationJson
        )
    end)
    
    return success
end

-- ═══════════════════════════════════════════════════════════════
-- DETECTION LOGIC - SCANS CONVEYOR BELT AND PLAYER BASES
-- ═══════════════════════════════════════════════════════════════

local function checkConveyor()
    -- Try multiple possible names for the conveyor
    local possibleNames = {"Conveyor", "ConveyorBelt", "Belt", "SpawnConveyor", "MainConveyor"}
    local conveyor = nil
    
    for _, name in ipairs(possibleNames) do
        conveyor = Workspace:FindFirstChild(name)
        if conveyor then break end
    end
    
    -- Also check in Workspace children deeply
    if not conveyor then
        for _, obj in pairs(Workspace:GetChildren()) do
            if obj:IsA("Model") or obj:IsA("Folder") then
                for _, child in pairs(obj:GetChildren()) do
                    if child.Name:lower():find("conveyor") or child.Name:lower():find("belt") then
                        conveyor = child
                        break
                    end
                end
            end
            if conveyor then break end
        end
    end
    
    return conveyor
end

local function scanForBrainrots()
    local found = {}
    
    -- 1. SCAN CONVEYOR BELT (Main source)
    local conveyor = checkConveyor()
    if conveyor then
        for _, obj in pairs(conveyor:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("Part") or obj:IsA("MeshPart") then
                local name = obj.Name
                local rarity = BRAINROTS[name]
                if rarity and NOTIFY_SETTINGS[rarity] then
                    table.insert(found, {
                        name = name,
                        rarity = rarity,
                        location = "Conveyor Belt",
                        obj = obj
                    })
                end
                
                -- Check for name tags/billboards above brainrots
                for _, child in pairs(obj:GetDescendants()) do
                    if child:IsA("BillboardGui") or child:IsA("TextLabel") or child:IsA("TextBox") then
                        if child.Text then
                            local textName = child.Text:gsub("%s+", " "):match("^%s*(.-)%s*$")
                            local textRarity = BRAINROTS[textName]
                            if textRarity and NOTIFY_SETTINGS[textRarity] then
                                table.insert(found, {
                                    name = textName,
                                    rarity = textRarity,
                                    location = "Conveyor Belt (Label)",
                                    obj = obj
                                })
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- 2. SCAN PLAYER BASES (Other players' brainrots)
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            -- Look for their base
            local base = Workspace:FindFirstChild(otherPlayer.Name .. "_Base") 
                      or Workspace:FindFirstChild(otherPlayer.Name .. "Base")
                      or Workspace:FindFirstChild(otherPlayer.Name .. "_Plot")
                      or Workspace:FindFirstChild(otherPlayer.Name .. "Plot")
            
            -- Also check for any folder/model with player name
            if not base then
                for _, obj in pairs(Workspace:GetChildren()) do
                    if obj.Name:find(otherPlayer.Name) and (obj:IsA("Model") or obj:IsA("Folder")) then
                        base = obj
                        break
                    end
                end
            end
            
            if base then
                for _, obj in pairs(base:GetDescendants()) do
                    if obj:IsA("Model") or obj:IsA("Part") then
                        local name = obj.Name
                        local rarity = BRAINROTS[name]
                        -- Only notify for high tier in bases to avoid spam
                        if rarity and (rarity == "OG" or rarity == "Secret" or rarity == "Brainrot God") then
                            table.insert(found, {
                                name = name,
                                rarity = rarity,
                                location = otherPlayer.Name .. "'s Base",
                                obj = obj
                            })
                        end
                    end
                end
            end
            
            -- Check their character (holding brainrots)
            local char = otherPlayer.Character
            if char then
                for _, obj in pairs(char:GetDescendants()) do
                    if obj:IsA("Tool") or obj:IsA("Model") then
                        local name = obj.Name
                        local rarity = BRAINROTS[name]
                        if rarity and (rarity == "OG" or rarity == "Secret") then
                            table.insert(found, {
                                name = name,
                                rarity = rarity,
                                location = otherPlayer.Name .. " (Holding)",
                                obj = obj
                            })
                        end
                    end
                end
            end
        end
    end
    
    -- 3. CHECK FOR SHOP/SPAWN AREAS
    local shop = Workspace:FindFirstChild("Shop") or Workspace:FindFirstChild("Store")
    if shop then
        for _, obj in pairs(shop:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("Part") then
                local name = obj.Name
                local rarity = BRAINROTS[name]
                if rarity and NOTIFY_SETTINGS[rarity] then
                    table.insert(found, {
                        name = name,
                        rarity = rarity,
                        location = "Shop",
                        obj = obj
                    })
                end
            end
        end
    end
    
    return found
end

