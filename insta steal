local function IsHoldingCarpet()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local character = LocalPlayer.Character
    if not character then return false end
    
    -- Check if carpet is equipped (in character)
    for _, item in pairs(character:GetChildren()) do
        if item:IsA("Tool") and (item.Name:lower():find("carpet") or item.Name:lower():find("magic")) then
            return true
        end
    end
    
    -- Alternative: Check if specific carpet tool exists
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item.Parent == character then
                if item.Name:lower():find("carpet") or item.Name:lower():find("fly") or item.Name:lower():find("magic") then
                    return true
                end
            end
        end
    end
    
    return false
end

local function FindBrainrotTargets()
    local targets = {}
    local myPos = HumanoidRootPart.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
            local targetHumanoid = player.Character:FindFirstChild("Humanoid")
            
            if targetHRP and targetHumanoid and targetHumanoid.Health > 0 then
                local distance = (targetHRP.Position - myPos).Magnitude
                if distance <= Config.StealDistance then
                    -- Check if they have "brainrot" or valuable items
                    local hasItem = false
                    for _, item in pairs(player.Character:GetChildren()) do
                        if item:IsA("Tool") or item:IsA("Accessory") then
                            -- Look for valuable items (adjust based on game)
                            if item.Name:lower():find("brainrot") or 
                               item.Name:lower():find("rare") or 
                               item.Name:lower():find("legendary") or
                               item.Name:lower():find("exclusive") then
                                hasItem = true
                                break
                            end
                        end
                    end
                    
                    if hasItem or distance <= 5 then -- Close range or has item
                        table.insert(targets, {
                            Player = player,
                            Distance = distance,
                            Position = targetHRP.Position
                        })
                    end
                end
            end
        end
    end
    
    -- Sort by distance
    table.sort(targets, function(a, b) return a.Distance < b.Distance end)
    return targets
end

local function StealBrainrot()
    if not Config.Enabled then return end
    if not Config.SavedPosition then
        warn("Set a position first! Press [T]")
        return
    end
    
    local targets = FindBrainrotTargets()
    if #targets == 0 then
        warn("No brainrot targets nearby!")
        return
    end
    
    local originalPosition = HumanoidRootPart.CFrame
    
    -- Teleport to target if enabled
    for _, target in pairs(targets) do
        -- Teleport to target
        local targetCFrame = CFrame.new(target.Position + Vector3.new(0, 3, 0))
        HumanoidRootPart.CFrame = targetCFrame
        
        wait(0.1)
        
        -- Attempt steal (game-specific, usually requires tool activation)
        local character = LocalPlayer.Character
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                -- Try to activate steal
                pcall(function()
                    tool:Activate()
                    if tool:FindFirstChild("RemoteEvent") then
                        tool.RemoteEvent:FireServer(target.Player)
                    end
                end)
            end
        end
        
        wait(0.2)
        
        -- Teleport back if enabled
        if Config.TeleportEnabled then
            HumanoidRootPart.CFrame = Config.SavedPosition * Config.TeleportOffset
        end
        
        break -- Steal from one target at a time
    end
end

