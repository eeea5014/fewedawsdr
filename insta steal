-- Input Handling
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Config.SetPositionKey then
        SetPosition()
    elseif input.KeyCode == Config.ToggleTeleportKey then
        ToggleTeleport()
    elseif input.KeyCode == Config.StealKey then
        if IsHoldingCarpet() then
            StealBrainrot()
        else
            CarpetLabel.Text = "🧶 Carpet: REQUIRED!"
            CarpetLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            wait(1)
            CarpetLabel.Text = "🧶 Carpet: NOT EQUIPPED"
            CarpetLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
        end
    end
end)

