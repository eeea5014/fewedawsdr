local function makeFakeButton(name, xPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 180, 0, 60)
    btn.Position = UDim2.new(0, xPos, 0, 0)
    btn.BackgroundColor3 = Color3.new(1, 1, 1)
    btn.BorderSizePixel = 0
    btn.Text = name
    btn.TextColor3 = Color3.new(0, 0, 0)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextScaled = true
    btn.Parent = ButtonHolder

    local outline = Instance.new("Frame")
    outline.Size = UDim2.new(1, 4, 1, 4)
    outline.Position = UDim2.new(0, -2, 0, -2)
    outline.BackgroundColor3 = Color3.new(1, 1, 1)
    outline.BorderSizePixel = 0
    outline.ZIndex = btn.ZIndex - 1
    outline.Parent = btn

    -- Cool hover animation (scale + slight rotation)
    local hoverTween = TweenService:Create(
        btn,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 190, 0, 70), Rotation = 2}
    )
    local unhoverTween = TweenService:Create(
        btn,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 180, 0, 60), Rotation = 0}
    )
    btn.MouseEnter:Connect(function() hoverTween:Play() end)
    btn.MouseLeave:Connect(function() unhoverTween:Play() end)

    -- Buttons do nothing (intentionally)
    btn.MouseButton1Click:Connect(function()
        -- No functionality
    end)
end

