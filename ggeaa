-- Helper to find the new trade machine Remote
local function findTradeRemote()
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and obj.Name:lower():find("trade") then
            return obj
        end
    end
    warn("Trade remote not found.")
    return nil
end

local TradeRemote = findTradeRemote()
