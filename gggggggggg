for _, child in pairs(ReplicatedStorage:GetDescendants()) do
    if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
        local name = string.lower(child.Name)
        if string.find(name, "steal") or string.find(name, "buy") or string.find(name, "equip") or string.find(name, "use") then
            table.insert(gameRemotes, child)
            print("Found potential remote: " .. child.Name)
        end
    end
