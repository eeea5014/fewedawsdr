-- Scan Player's character or backpack for usable items/gears
local function scanForGears()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        for _, child in pairs(LocalPlayer.Character:GetDescendants()) do
            if child:IsA("Tool") or child:IsA("BasePart") and child:FindFirstChild("ParticleEmitter") or child:FindFirstChild("Fire") then
                table.insert(characterEffects, child)
            end
        end
    end
    if LocalPlayer:FindFirstChild("Backpack") then
        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(gears, tool)
            end
        end
    end
end
scanForGears()
LocalPlayer.CharacterAdded:Connect(scanForGears)


-- Lagging Logic
local function startServerLag()
    StatusLabel.Text = "Status: Lagging Server..."
    for _, remote in pairs(gameRemotes) do
        if remote:IsA("RemoteEvent") then
            local conn
            conn = RunService.Heartbeat:Connect(function()
                if isLagging then
                    -- Fire with junk data to confuse the server
                    remote:FireServer(HttpService:GenerateGUID(true), tick(), workspace)
                else
                    conn:Disconnect()
                end
            end)
            table.insert(lagConnections, conn)
        end
    end
end

local function startVisualSpam()
