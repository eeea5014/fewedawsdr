    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if isSpamming then
            -- Clone and move existing effects to create visual clutter for others
            for _, effect in pairs(characterEffects) do
                if effect and effect.Parent then
                    local clone = effect:Clone()
                    clone.Parent = workspace
                    if clone:IsA("BasePart") then
                        clone.Position = rootPart.Position + Vector3.new(math.random(-20, 20), math.random(5, 15), math.random(-20, 20))
                    end
                    game.Debris:AddItem(clone, 0.5) -- Add to debris to clean up after a short time
