local desyncActive = false
local flagsApplied = false

-- Função para encontrar Quantum Cloner
local function findQuantumCloner()
    local cloner = backpack:FindFirstChild("Quantum Cloner")
    if not cloner then
        cloner = character:FindFirstChild("Quantum Cloner")
    end
    return cloner
end

-- Função para equipar Quantum Cloner
local function equipQuantumCloner()
    local cloner = findQuantumCloner()
    
    if not cloner then
        statusLabel.Text = "Status: Erro\nQuantum Cloner não encontrado!\nFlags: " .. (flagsApplied and #quantumDesyncFlags or 0)
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return false
    end
    
    if cloner.Parent == backpack then
        character.Humanoid:EquipTool(cloner)
        task.wait(0.3)
    end
    
    statusLabel.Text = "Status: Quantum Cloner equipado\nPreparando desync...\nFlags: " .. (flagsApplied and #quantumDesyncFlags or 0)
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    return true
end

-- Função para aplicar FastFlags
local function applyQuantumFlags()
    if flagsApplied then return end
    
    local successCount = 0
    
    for i, flag in ipairs(quantumDesyncFlags) do
        local success = pcall(function()
            setfflag(flag[1], flag[2])
        end)
        
        if success then
            successCount = successCount + 1
        end
    end
    
    flagsApplied = true
    return successCount
end

-- Função principal de desync
local function activateQuantumDesync()
    if desyncActive then
        statusLabel.Text = "Status: Desync já ativo!\nQuantum Cloner: Ativo\nFlags: " .. #quantumDesyncFlags
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        return
    end
    
    -- Aplicar flags primeiro
    local flagCount = applyQuantumFlags()
    task.wait(0.2)
    
    -- Equipar Quantum Cloner
    if not equipQuantumCloner() then
        return
    end
    
    task.wait(0.5)
    
    -- Procurar remote events no caminho correto
    local packages = ReplicatedStorage:WaitForChild("Packages", 5)
    if not packages then
        statusLabel.Text = "Status: Erro\nPackages não encontrado!\nFlags: " .. flagCount
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        warn("❌ Packages não encontrado")
        return
    end
    
    local netFolder = packages:WaitForChild("Net", 5)
    if not netFolder then
        statusLabel.Text = "Status: Erro\nNet folder não encontrado!\nFlags: " .. flagCount
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        warn("❌ Net folder não encontrado")
        return
    end
    
    local useItemRemote = netFolder:WaitForChild("RE/UseItem", 5)
    local teleportRemote = netFolder:WaitForChild("RE/QuantumCloner/OnTeleport", 5)
    
    if not useItemRemote or not teleportRemote then
        statusLabel.Text = "Status: Erro\nRemotos não encontrados!\nFlags: " .. flagCount
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        warn("❌ Remotos não encontrados")
        return
    end
    
    statusLabel.Text = "Status: Ativando desync...\nCriando clone...\nFlags: " .. flagCount
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    -- Usar Quantum Cloner (cria clone)
    local success1 = pcall(function()
        useItemRemote:FireServer("Quantum Cloner")
    end)
    
    task.wait(0.15)
    
    -- Usar OnTeleport (teleporta original)
    local success2 = pcall(function()
        teleportRemote:FireServer()
    end)
    
    if success1 and success2 then
        desyncActive = true
        statusLabel.Text = "Status: DESYNC ATIVO!\nClone criado + Teleport\nFlags: " .. flagCount .. "/" .. #quantumDesyncFlags
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        testButton.Text = "Desync Ativo! (Quantum)"
        testButton.BackgroundColor3 = Color3.fromRGB(20, 70, 20)
        testButton.TextColor3 = Color3.fromRGB(150, 255, 150)
        
        print("[Borralho test] Quantum Desync ativado com sucesso!")
        print("Clone criado na posição original")
        print("Personagem teleportado com " .. flagCount .. " flags aplicadas")
    else
        statusLabel.Text = "Status: Erro ao usar itens\nVerifique RemoteEvent\nFlags: " .. flagCount
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

