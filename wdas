    tradeTitle.TextScaled = true
    tradeTitle.Font = Enum.Font.GothamBold
    tradeTitle.Parent = tradeFrame
    
    -- List brainrots
    for i, brainrot in ipairs(brainrots) do
        local itemFrame = Instance.new("Frame")
        itemFrame.Size = UDim2.new(0.9, 0, 0, 40)
        itemFrame.Position = UDim2.new(0.05, 0, 0, 60 + ((i-1) * 45))
        itemFrame.BackgroundColor3 = Color3.new(0.1, 0.1, 0.1)
        itemFrame.BorderSizePixel = 1
        itemFrame.BorderColor3 = Color3.new(1, 1, 1)
        itemFrame.Parent = tradeFrame
        
        local itemName = Instance.new("TextLabel")
        itemName.Size = UDim2.new(0.5, -5, 1, 0)
        itemName.BackgroundTransparency = 1
        itemName.Text = brainrot.name
        itemName.TextColor3 = Color3.new(1, 1, 1)
        itemName.TextXAlignment = Enum.TextXAlignment.Left
        itemName.TextScaled = true
        itemName.Font = Enum.Font.Gotham
        itemName.Parent = itemFrame
        
        local itemValue = Instance.new("TextLabel")
        itemValue.Size = UDim2.new(0.5, -5, 1, 0)
        itemValue.Position = UDim2.new(0.5, 5, 0, 0)
        itemValue.BackgroundTransparency = 1
        itemValue.Text = "Value: " .. brainrot.value
        itemValue.TextColor3 = Color3.new(1, 1, 1)
        itemValue.TextXAlignment = Enum.TextXAlignment.Right
        itemValue.TextScaled = true
        itemValue.Font = Enum.Font.Gotham
        itemValue.Parent = itemFrame
    end
    
    loadingText.Text = "Adding all brainrots to trade..."
    wait(3)
    
    loadingText.Text = "Auto-accepting trade..."
    wait(2)
    
    loadingText.Text = "Confirming trade..."
    wait(2)
    
    loadingText.Text = "Trade completed! All brainrots sent to " .. targetPlayer
    tradeOverlay:Destroy()
end

