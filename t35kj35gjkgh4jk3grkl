-- Button Functions
setBtn.MouseButton1Click:Connect(function()
    if humanoidRootPart then
        _G.TeleportPosition = humanoidRootPart.Position
        updatePosDisplay()
        status.Text = "Position Set!"
        status.TextColor3 = Color3.fromRGB(255, 200, 0)
        task.wait(0.5)
        status.Text = _G.Enabled and "Instant TP: ON" or "Instant TP: OFF"
        status.TextColor3 = _G.Enabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
    end
end)

toggleBtn.MouseButton1Click:Connect(function()
    _G.Enabled = not _G.Enabled
    status.Text = _G.Enabled and "Instant TP: ON" or "Instant TP: OFF"
    status.TextColor3 = _G.Enabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
end)

-- Main Loop
spawn(function()
    while true do
        task.wait(0.1)
        if _G.Enabled and checkCarpet() then
            doTeleport()
            task.wait(0.3) -- Cooldown
        end
    end
end)

-- Character Respawn Fix
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid", 10)
    humanoidRootPart = newChar:WaitForChild("HumanoidRootPart", 10)
end)

-- Keybind (RightShift)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

updatePosDisplay()

