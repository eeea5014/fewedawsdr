-- Functions
local function updatePosDisplay()
    local pos = _G.TeleportPosition
    posDisplay.Text = string.format("Target: %.0f, %.0f, %.0f", pos.X, pos.Y, pos.Z)
end

local function checkCarpet()
    if not character then return false end
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") and string.find(tool.Name:lower(), _G.CarpetName:lower()) then
            return true
        end
    end
    return false
end

local function doTeleport()
    if not humanoidRootPart then return end
    if not checkCarpet() then return end

    local target = _G.TeleportPosition
    local current = humanoidRootPart.Position

    if (current - target).Magnitude < 5 then return end

    -- Method: Direct CFrame with velocity reset
    humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
    humanoidRootPart.CFrame = CFrame.new(target)
    humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
end

