--// KEYBOARD SHORTCUTS
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.teleportKey then
        teleportToMouse()
    elseif input.KeyCode == CONFIG.setPosKey then
        if humanoidRootPart then
            currentSetPosition = humanoidRootPart.CFrame
            setPosText.Text = string.format("Set Pos: X:%.0f Y:%.0f Z:%.0f", 
                currentSetPosition.X, currentSetPosition.Y, currentSetPosition.Z)
            notify("📌 Quick Set!", Color3.fromRGB(0, 150, 255))
        end
    elseif input.KeyCode == CONFIG.toggleMouseKey then
        mouseEnabled = true
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == CONFIG.toggleMouseKey then
        mouseEnabled = false
        -- Only lock if not hovering over GUI
        if not mainFrame:IsMouseOver() then
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
        end
    end
end)

-- Keep mouse unlocked when over GUI
mainFrame.MouseEnter:Connect(function()
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    UserInputService.MouseIconEnabled = true
end)

mainFrame.MouseLeave:Connect(function()
    if not mouseEnabled then
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    end
end)

