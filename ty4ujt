btnSave.MouseButton1Click:Connect(function()
    if not humanoidRootPart then return end
    if #savedLocations >= CONFIG.maxSavedLocations then
        notify("❌ Max 6 locations!", Color3.fromRGB(255, 50, 50))
        return
    end
    
    local locData = {
        cframe = humanoidRootPart.CFrame,
        name = "Loc " .. (#savedLocations + 1),
        pos = humanoidRootPart.Position
    }
    table.insert(savedLocations, locData)
    
    -- Create button
    local locBtn = Instance.new("TextButton")
    locBtn.Size = UDim2.new(1, -10, 0, 35)
    locBtn.Position = UDim2.new(0, 5, 0, 0)
    locBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    locBtn.BorderSizePixel = 0
    locBtn.Text = string.format("📍 %s (%.0f, %.0f, %.0f)", locData.name, locData.pos.X, locData.pos.Y, locData.pos.Z)
    locBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    locBtn.TextSize = 12
    locBtn.Font = Enum.Font.Gotham
    locBtn.Parent = savedFrame
    
    local locCorner = Instance.new("UICorner")
    locCorner.CornerRadius = UDim.new(0, 6)
    locCorner.Parent = locBtn
    
    -- Click to teleport
    local index = #savedLocations
    locBtn.MouseButton1Click:Connect(function()
        if savedLocations[index] then
            doTeleport(savedLocations[index].cframe)
        end
    end)
    
    -- Right click to delete
    locBtn.MouseButton2Click:Connect(function()
        locBtn:Destroy()
        savedLocations[index] = nil
        notify("🗑️ Deleted " .. locData.name, Color3.fromRGB(255, 100, 100))
    end)
    
    -- Update canvas size
    savedFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
    notify("💾 Saved " .. locData.name, Color3.fromRGB(150, 50, 255))
end)

