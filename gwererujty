--// Game Functions
local function GetCases()
    local cases = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name:lower():find("case") then
            if obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Handle") then
                table.insert(cases, obj)
            end
        end
    end
    return cases
end

local function GetNearestCase()
    local nearest, dist = nil, math.huge
    local cases = GetCases()
    
    for _, case in pairs(cases) do
        local part = case:FindFirstChild("HumanoidRootPart") or case:FindFirstChild("Handle") or case:FindFirstChildWhichIsA("BasePart")
        if part then
            local magnitude = (part.Position - HumanoidRootPart.Position).Magnitude
            if magnitude < dist and magnitude < Settings.CollectRange then
                dist = magnitude
                nearest = part
            end
        end
    end
    return nearest
end

local function CollectCase(casePart)
    if not casePart then return end
    
    -- Tween to case
    local distance = (casePart.Position - HumanoidRootPart.Position).Magnitude
    local tweenTime = math.clamp(distance / Settings.WalkSpeed, 0.5, 3)
    
    local tween = TweenService:Create(HumanoidRootPart, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(casePart.Position + Vector3.new(0, 3, 0))
    })
    
    tween:Play()
    tween.Completed:Wait()
    
    -- Touch/interact with case
    firetouchinterest(HumanoidRootPart, casePart, 0)
    task.wait(0.1)
    firetouchinterest(HumanoidRootPart, casePart, 1)
    
    StatusText.Text = "✅ Collected: " .. casePart.Parent.Name
end

local function SellCases()
    -- Find sell NPC/Zone
    local sellZone = workspace:FindFirstChild("Sell") or workspace:FindFirstChild("SellZone")
    if sellZone then
        local part = sellZone:FindFirstChildWhichIsA("BasePart")
        if part then
            StatusText.Text = "💰 Selling cases..."
            
            local tween = TweenService:Create(HumanoidRootPart, TweenInfo.new(2, Enum.EasingStyle.Quad), {
                CFrame = CFrame.new(part.Position + Vector3.new(0, 5, 0))
            })
            tween:Play()
            tween.Completed:Wait()
            
            -- Trigger sell remote
            local sellRemote = ReplicatedStorage:FindFirstChild("Sell") or ReplicatedStorage:FindFirstChild("SellCases")
            if sellRemote then
                sellRemote:FireServer()
            end
            
            task.wait(1)
            StatusText.Text = "⏳ Status: Idle"
        end
    end
end

local function DoRebirth()
    local rebirthRemote = ReplicatedStorage:FindFirstChild("Rebirth") or ReplicatedStorage:FindFirstChild("DoRebirth")
    if rebirthRemote then
        StatusText.Text = "🔄 Rebirthing..."
        rebirthRemote:FireServer()
        task.wait(2)
        StatusText.Text = "⏳ Status: Idle"
    end
end

