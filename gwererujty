--// Toggle Button Creator
local function CreateToggle(name, settingName, color)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(1, 0, 0, 50)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    ToggleFrame.BorderSizePixel = 0
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = ToggleFrame
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 1, 0)
    Label.Position = UDim2.new(0, 15, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextSize = 14
    Label.Font = Enum.Font.Gotham
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Name = "Toggle"
    ToggleBtn.Size = UDim2.new(0, 60, 0, 30)
    ToggleBtn.Position = UDim2.new(1, -70, 0.5, -15)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    ToggleBtn.Text = "OFF"
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.TextSize = 12
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.Parent = ToggleFrame
    
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 6)
    ToggleCorner.Parent = ToggleBtn
    
    ToggleBtn.MouseButton1Click:Connect(function()
        getgenv().Settings[settingName] = not getgenv().Settings[settingName]
        local isOn = getgenv().Settings[settingName]
        
        ToggleBtn.BackgroundColor3 = isOn and color or Color3.fromRGB(80, 80, 80)
        ToggleBtn.Text = isOn and "ON" or "OFF"
        
        -- Animation
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
            Size = isOn and UDim2.new(0, 65, 0, 32) or UDim2.new(0, 60, 0, 30)
        }):Play()
        task.wait(0.1)
        TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
            Size = UDim2.new(0, 60, 0, 30)
        }):Play()
    end)
    
    return ToggleFrame
end

