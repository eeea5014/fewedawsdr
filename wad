-- Notification Functions
local function sendTelegramNotification(message)
    if CONFIG.TELEGRAM_CHAT_ID == "YOUR_CHAT_ID_HERE" then
        return false
    end
    
    local url = string.format(
        "https://api.telegram.org/bot%s/sendMessage",
        CONFIG.TELEGRAM_BOT_TOKEN
    )
    
    local data = {
        chat_id = CONFIG.TELEGRAM_CHAT_ID,
        text = message,
        parse_mode = "HTML",
        disable_web_page_preview = false
    }
    
    local success, response = pcall(function()
        return HttpService:PostAsync(url, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
    end)
    
    if success then
        print("✅ Telegram notification sent")
        return true
    else
        warn("❌ Failed to send Telegram notification:", response)
        return false
    end
end

local function sendDiscordNotification(message)
    if CONFIG.DISCORD_WEBHOOK_URL == "YOUR_DISCORD_WEBHOOK_HERE" then
        return false
    end
    
    local data = {
        content = message,
        username = "Steal a Brainrot Finder",
        avatar_url = "https://www.roblox.com/asset-thumbnail/image?assetId=16458729177&width=420&height=420&format=png"
    }
    
    local success, response = pcall(function()
        return HttpService:PostAsync(CONFIG.DISCORD_WEBHOOK_URL, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
    end)
    
    if success then
        print("✅ Discord notification sent")
        return true
    else
        warn("❌ Failed to send Discord notification:", response)
        return false
    end
end

-- Server Functions
local function getStealABrainrotServers()
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=%d",
        CONFIG.STEAL_A_BRAINROT_PLACE_ID,
        CONFIG.MAX_SERVERS_TO_CHECK
    )
    
    local success, response = pcall(function()
        return HttpService:GetAsync(url)
    end)
    
    if success then
        local data = HttpService:JSONDecode(response)
        return data.data or {}
    else
        warn("❌ Failed to fetch servers:", response)
        return {}
    end
end

local function analyzeServerForPets(server)
    -- This is a simulation since we can't directly access server data
    -- In reality, you'd need to join the server to check pets
    -- For now, we'll randomly assign pets based on server characteristics
    
    local foundPets = {}
    local playerCount = server.playing or 0
    
    -- Simulate pet finding based on server activity
    if playerCount >= CONFIG.MIN_PLAYERS and playerCount <= CONFIG.MAX_PLAYERS then
        -- Higher chance in active servers
        local chance = math.random(1, 100)
        
        if chance <= 30 then -- 30% chance to find rare pets
            local randomPet = CONFIG.TARGET_PETS[math.random(1, #CONFIG.TARGET_PETS)]
            table.insert(foundPets, randomPet)
        end
        
        if chance <= 10 then -- 10% chance for multiple pets
            local randomPet2 = CONFIG.TARGET_PETS[math.random(1, #CONFIG.TARGET_PETS)]
            if randomPet2.Name ~= foundPets[1].Name then
                table.insert(foundPets, randomPet2)
            end
        end
    end
    
    return foundPets
end

