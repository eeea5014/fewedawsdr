-- Main Search Function
local function searchForPets()
    StatusLabel.Text = "Status: Searching Steal a Brainrot servers..."
    
    local servers = getStealABrainrotServers()
    local serversWithPets = 0
    
    for _, server in pairs(servers) do
        local pets = analyzeServerForPets(server)
        
        if #pets > 0 then
            addFoundServer(server, pets)
            serversWithPets = serversWithPets + 1
            
            -- Limit to prevent spam
            if serversWithPets >= 3 then
                break
            end
        end
        
        wait(0.1) -- Rate limiting
    end
    
    StatusLabel.Text = string.format("Status: Found %d servers with target pets", serversWithPets)
end

