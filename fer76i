--// ESP Functions
local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    
    local espFolder = Instance.new("Folder")
    espFolder.Name = player.Name .. "_ESP"
    
    -- Box
    local box = Instance.new("BoxHandleAdornment")
    box.Size = Vector3.new(4, 6, 4)
    box.Color3 = Color3.fromRGB(0, 255, 255)
    box.Transparency = 0.7
    box.ZIndex = 10
    box.AlwaysOnTop = true
    box.Adornee = nil
    box.Parent = espFolder
    
    -- Name Tag
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Parent = billboard
    
    billboard.Parent = espFolder
    espFolder.Parent = game.CoreGui
    
    ESPObjects[player] = {
        Folder = espFolder,
        Box = box,
        Billboard = billboard,
        NameLabel = nameLabel,
    }
    
    -- Update connection
    local connection = RunService.RenderStepped:Connect(function()
        if not Config.FriendESPEnabled then
            espFolder.Enabled = false
            return
        end
        
        local character = player.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local hrp = character.HumanoidRootPart
            local isFriend = Config.FriendList[player.UserId] or false
            
            espFolder.Enabled = true
            box.Adornee = hrp
            
            if isFriend then
                box.Color3 = Color3.fromRGB(0, 255, 100) -- Green for friends
                nameLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                nameLabel.Text = player.Name .. " [FRIEND]"
            else
                box.Color3 = Color3.fromRGB(255, 50, 50) -- Red for enemies
                nameLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                nameLabel.Text = player.Name .. " [ENEMY]"
            end
            
            billboard.Adornee = hrp
        else
            espFolder.Enabled = false
            box.Adornee = nil
        end
    end)
    
    ESPObjects[player].Connection = connection
end

local function RemoveESP(player)
    if ESPObjects[player] then
        if ESPObjects[player].Connection then
            ESPObjects[player].Connection:Disconnect()
        end
        if ESPObjects[player].Folder then
            ESPObjects[player].Folder:Destroy()
        end
        ESPObjects[player] = nil
    end
end

--// Teleport Function (Safe)
local function SafeTeleport(position)
    local character = LocalPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Use CFrame for instant teleport
    hrp.CFrame = CFrame.new(position + Vector3.new(0, 5, 0)) -- Slightly above ground
    
    -- Alternative: Tween for smoother teleport (uncomment if needed)
    --[[
    local tween = TweenService:Create(hrp, TweenInfo.new(0.1), {
        CFrame = CFrame.new(position + Vector3.new(0, 5, 0))
    })
    tween:Play()
    --]]
end

--// Check if holding carpet (Saber Simulator specific)
local function IsHoldingCarpet()
    local character = LocalPlayer.Character
    if not character then return false end
    
    -- Check backpack for carpet tool or equipped tool
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local equipped = character:FindFirstChildOfClass("Tool")
    
    -- Common carpet names in steal games
    local carpetNames = {"Carpet", "FlyingCarpet", "MagicCarpet", "Fly", "FlyTool"}
    
    if equipped then
        for _, name in ipairs(carpetNames) do
            if equipped.Name:lower():find(name:lower()) then
                return true
            end
        end
    end
    
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            for _, name in ipairs(carpetNames) do
                if tool.Name:lower():find(name:lower()) then
                    return true
                end
            end
        end
    end
    
    return false
end

--// Auto-equip carpet if available
local function EquipCarpet()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return false end
    
    local carpetNames = {"Carpet", "FlyingCarpet", "MagicCarpet", "Fly", "FlyTool"}
    
    for _, tool in ipairs(backpack:GetChildren()) do
        for _, name in ipairs(carpetNames) do
            if tool.Name:lower():find(name:lower()) then
                tool.Parent = LocalPlayer.Character
                return true
            end
        end
    end
    
    return false
end

