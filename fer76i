-- Instant Steal Logic
UI.InstantStealBtn.MouseButton1Click:Connect(function()
    -- Validation
    if not SavedPositions.TargetBase then
        UI.InstantStealBtn.Text = "SET POS 1 FIRST!"
        UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(1)
        UI.InstantStealBtn.Text = "INSTANT STEAL"
        UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        return
    end
    
    if not SavedPositions.EscapeSpot then
        UI.InstantStealBtn.Text = "SET POS 2 FIRST!"
        UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(1)
        UI.InstantStealBtn.Text = "INSTANT STEAL"
        UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        return
    end
    
    -- Check/Equip carpet
    if not IsHoldingCarpet() then
        EquipCarpet()
    end
    
    -- Visual feedback - Executing
    UI.InstantStealBtn.Text = "STEALING..."
    UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
    
    -- Step 1: Teleport to target base
    SafeTeleport(SavedPositions.TargetBase)
    
    -- Step 2: Wait for steal to process (custom delay)
    task.wait(Config.StealDelay)
    
    -- Step 3: Teleport to escape spot
    SafeTeleport(SavedPositions.EscapeSpot)
    
    -- Reset button
    UI.InstantStealBtn.Text = "INSTANT STEAL"
    UI.InstantStealBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
end)

-- Insta Leave (Emergency Escape)
