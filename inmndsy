    end
end)

btnTPMouse.MouseButton1Click:Connect(function()
    teleportToMouse()
end)

btnSaveLoc.MouseButton1Click:Connect(function()
    if not humanoidRootPart then return end
    
    if #savedLocations >= CONFIG.maxSavedLocations then
        notify("❌ Max locations saved!", Color3.fromRGB(255, 85, 0))
        return
    end
    
    table.insert(savedLocations, {
        cframe = humanoidRootPart.CFrame,
        name = "Loc #" .. #savedLocations + 1
    })
    
    -- Create button for saved location
    local locButton = createButton("LocBtn", "📍 " .. savedLocations[#savedLocations].name, UDim2.new(0, 0, 0, 0), Color3.fromRGB(100, 100, 100), savedFrame)
    locButton.Size = UDim2.new(1, 0, 0, 30)
    locButton.TextSize = 14
    
    local locIndex = #savedLocations
    
    locButton.MouseButton1Click:Connect(function()
        teleportToCFrame(savedLocations[locIndex].cframe)
    end)
    
    -- Right click to delete
    locButton.MouseButton2Click:Connect(function()
        locButton:Destroy()
        table.remove(savedLocations, locIndex)
        notify("🗑️ Location deleted!", Color3.fromRGB(255, 85, 0))
    end)
    
    notify("💾 Location Saved!", Color3.fromRGB(140, 0, 255))
end)

--// KEYBOARD SHORTCUTS
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.teleportKey then
        teleportToMouse()
    elseif input.KeyCode == CONFIG.setPosKey then
        if humanoidRootPart then
            currentSetPosition = humanoidRootPart.CFrame
            notify("📌 Quick Position Set!", Color3.fromRGB(0, 120, 255))
        end
    elseif input.KeyCode == CONFIG.guiKey then
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == CONFIG.guiKey then
        if not guiVisible then
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
            UserInputService.MouseIconEnabled = false
        end
    end
end)

--// TOGGLE GUI VISIBILITY (Right Ctrl)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        guiVisible = not guiVisible
        mainFrame.Visible = guiVisible
        notify(guiVisible and "👁️ GUI Shown" or "👁️ GUI Hidden", Color3.fromRGB(100, 100, 100))
    end
end)

--// DRAGGABLE GUI
local dragging = false
local dragStart = nil
local startPos = nil

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

